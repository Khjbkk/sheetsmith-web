---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.publishDate <= new Date()))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const categoryLabels: Record<string, string> = {
  por1: 'ป.1',
  mor1: 'ม.1',
  mor4: 'ม.4',
  general: 'ทั่วไป',
  tips: 'เทคนิค',
};
---

<BaseLayout
  title="บทความ — เทคนิคเตรียมสอบเข้า ป.1 ม.1 ม.4"
  description="รวมบทความเทคนิคเตรียมสอบเข้า ป.1 ม.1 ม.4 คำแนะนำจากผู้เชี่ยวชาญ วิธีเตรียมตัวลูก แนวข้อสอบ และเคล็ดลับสอบติด"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ label: 'บทความ' }]} />

    <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-8">บทความ</h1>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="group block">
            <div class="bg-white border border-border rounded-xl p-6 hover:shadow-lg hover:border-primary/30 transition-all h-full">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 bg-primary/10 text-primary text-xs font-medium rounded-md">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <time class="text-xs text-text-light" datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h2 class="font-heading font-semibold text-text group-hover:text-primary transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-text-light line-clamp-3">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-text-light text-center bg-white border border-border rounded-xl p-12">
        กำลังเตรียมบทความ เร็วๆ นี้
      </p>
    )}
  </div>
</BaseLayout>
