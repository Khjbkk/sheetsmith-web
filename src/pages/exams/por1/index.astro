---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ExamCard from '../../../components/ExamCard.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const exams = (await getCollection('exams', ({ data }) => data.publishDate <= new Date()))
  .filter((e) => e.data.level === 'por1')
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const freeExams = exams.filter((e) => e.data.isFree);

const subjects = [
  { name: 'เชาว์ปัญญา / IQ', icon: '🧠', desc: 'ทดสอบการเปรียบเทียบ การจัดหมวดหมู่ การหาความสัมพันธ์' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'การอ่าน การเขียน คำศัพท์ สะกดคำ' },
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'จำนวนนับ การบวกลบ รูปทรง แบบรูป' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'ตัวอักษร คำศัพท์พื้นฐาน ประโยคง่ายๆ' },
  { name: 'ความพร้อมด้านต่างๆ', icon: '🎯', desc: 'ทักษะการสังเกต การฟัง การปฏิบัติตามคำสั่ง' },
];

const faqItems = [
  {
    question: 'สอบเข้า ป.1 สาธิตจุฬาสอบอะไรบ้าง?',
    answer: 'การสอบเข้า ป.1 สาธิตจุฬาจะทดสอบความพร้อมของเด็กในหลายด้าน ได้แก่ เชาว์ปัญญา (IQ) ภาษาไทย คณิตศาสตร์ ภาษาอังกฤษ และความพร้อมด้านต่างๆ เช่น การฟัง การสังเกต การปฏิบัติตามคำสั่ง โดยข้อสอบจะเหมาะกับวัยและพัฒนาการของเด็กอายุ 5-6 ปี',
  },
  {
    question: 'ควรเตรียมตัวสอบเข้า ป.1 ล่วงหน้ากี่เดือน?',
    answer: 'แนะนำให้เริ่มเตรียมตัวล่วงหน้า 6-12 เดือน โดยเริ่มจากการทำความคุ้นเคยกับรูปแบบข้อสอบ ฝึกทำข้อสอบตัวอย่างทีละน้อย และค่อยๆ เพิ่มความยากขึ้น ไม่ควรกดดันเด็กมากเกินไป ควรให้เด็กสนุกกับการเรียนรู้',
  },
  {
    question: 'ข้อสอบ ป.1 สาธิตเกษตรต่างจากสาธิตจุฬาไหม?',
    answer: 'แนวข้อสอบมีความคล้ายคลึงกัน แต่รายละเอียดและน้ำหนักแต่ละวิชาอาจต่างกัน สาธิตเกษตรอาจเน้นทักษะด้านธรรมชาติและสิ่งแวดล้อมมากกว่า การฝึกทำข้อสอบหลากหลายแนวจะช่วยให้เด็กพร้อมสอบได้ทุกโรงเรียน',
  },
  {
    question: 'เด็กอายุเท่าไหร่สอบเข้า ป.1 ได้?',
    answer: 'โรงเรียนสาธิตส่วนใหญ่รับเด็กอายุ 5-6 ปี โดยนับอายุ ณ วันที่ 1 มิถุนายนของปีที่เข้าเรียน แต่ละโรงเรียนอาจมีเกณฑ์อายุต่างกันเล็กน้อย ควรตรวจสอบจากประกาศรับสมัครของโรงเรียนโดยตรง',
  },
];
---

<BaseLayout
  title="ข้อสอบเข้า ป.1 — รวมแนวข้อสอบสาธิตจุฬา สาธิตเกษตร และโรงเรียนชั้นนำ"
  description="รวมตัวอย่างข้อสอบเข้า ป.1 สาธิตจุฬา สาธิตเกษตร พร้อมเฉลยละเอียด ฝึกทำข้อสอบเชาว์ปัญญา คณิต ไทย อังกฤษ เตรียมพร้อมสอบเข้าสาธิต"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ป.1' },
    ]} />

    <header class="mb-12">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ป.1 — รวมแนวข้อสอบสาธิตจุฬา สาธิตเกษตร และโรงเรียนชั้นนำ
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          การสอบเข้า ป.1 ของโรงเรียนสาธิตและโรงเรียนชั้นนำเป็นก้าวแรกที่สำคัญในเส้นทางการศึกษาของลูก โรงเรียนสาธิตจุฬาลงกรณ์มหาวิทยาลัย สาธิตเกษตร สาธิตประสานมิตร และโรงเรียนชั้นนำอื่นๆ ล้วนมีการสอบคัดเลือกที่ทดสอบความพร้อมของเด็กในหลายด้าน
        </p>
        <p>
          SheetSmith รวบรวมแนวข้อสอบจากสนามสอบจริง พร้อมเฉลยละเอียดที่อธิบายวิธีคิดทุกข้อ ช่วยให้ลูกของคุณคุ้นเคยกับรูปแบบข้อสอบและเตรียมพร้อมอย่างมั่นใจ
        </p>
      </div>
    </header>

    <!-- วิชาที่สอบ -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-6">วิชาที่สอบเข้า ป.1</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {subjects.map((s) => (
          <div class="bg-white border border-border rounded-xl p-5 hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="font-heading font-semibold text-text mb-1">{s.name}</h3>
            <p class="text-sm text-text-light">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ตัวอย่างข้อสอบฟรี -->
    {freeExams.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-bold text-text mb-6">ตัวอย่างข้อสอบเข้า ป.1 ฟรี</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {freeExams.map((exam) => (
            <ExamCard
              title={exam.data.title}
              description={exam.data.description}
              level={exam.data.level}
              subject={exam.data.subject}
              questionCount={exam.data.questionCount}
              difficulty={exam.data.difficulty}
              isFree={exam.data.isFree}
              href={`/exams/por1/${exam.id}/`}
            />
          ))}
        </div>
      </section>
    )}

    <!-- คู่มือเตรียมสอบ -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">คู่มือเตรียมสอบเข้า ป.1</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          <li>
            <a href="/guides/how-to-prepare-por1/" class="text-primary hover:text-primary-dark font-medium transition-colors">
              คู่มือเตรียมสอบเข้า ป.1 สาธิต ฉบับสมบูรณ์ &rarr;
            </a>
          </li>
          <li>
            <a href="/blog/when-to-start-por1-prep/" class="text-primary hover:text-primary-dark font-medium transition-colors">
              ลูกอายุเท่าไหร่ควรเริ่มเตรียมสอบเข้า ป.1 &rarr;
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection title="คำถามที่พบบ่อยเกี่ยวกับสอบเข้า ป.1" items={faqItems} />

    <!-- CTA -->
    <CTABanner
      title="เริ่มเตรียมสอบเข้า ป.1 วันนี้"
      description="ดาวน์โหลดตัวอย่างข้อสอบฟรี พร้อมเฉลยละเอียด ให้ลูกคุ้นเคยกับข้อสอบจริง"
      buttonText="ดูตัวอย่างข้อสอบฟรี"
      buttonHref="/exams/"
    />
  </div>
</BaseLayout>
