---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'เชาว์ปัญญา / IQ', icon: '🧠', desc: 'การหาความสัมพันธ์ การจัดประเภท การเปรียบเทียบ และการคิดเป็นเหตุเป็นผล — เป็นวิชาที่สาธิตจุฬาให้น้ำหนักมาก', emphasis: 'high' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'การฟัง การอ่าน คำศัพท์พื้นฐาน และความเข้าใจประโยคง่ายๆ ตามวัย 5-6 ปี', emphasis: 'normal' },
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'จำนวนนับ การเปรียบเทียบมาก-น้อย รูปทรง และแบบรูปต่อเนื่อง', emphasis: 'normal' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'ตัวอักษร A-Z คำศัพท์ในชีวิตประจำวัน และความคุ้นเคยกับเสียง', emphasis: 'normal' },
  { name: 'ความพร้อมและทักษะ', icon: '🎯', desc: 'การฟังคำสั่ง การสังเกต ความตั้งใจ และการทำงานเป็นกลุ่ม — สาธิตจุฬาเน้นด้านนี้มาก', emphasis: 'high' },
];

const faqItems = [
  {
    question: 'ข้อสอบเข้า ป.1 สาธิตจุฬา ยากกว่าสาธิตอื่นไหม?',
    answer: 'ข้อสอบเข้า ป.1 สาธิตจุฬาเป็นที่ทราบกันว่ามีระดับการแข่งขันสูงที่สุดในกลุ่มโรงเรียนสาธิต เพราะมีผู้สมัครจำนวนมากเทียบกับที่นั่งที่จำกัด ในแง่เนื้อหาวิชาการ ความยากใกล้เคียงกับสาธิตเกษตรและสาธิตประสานมิตร แต่ในแง่จำนวนผู้แข่งขัน สาธิตจุฬายืนหนึ่ง ข้อสอบไม่ได้เน้นเนื้อหาวิชาการที่ลึก แต่เน้นความพร้อม เชาว์ปัญญา และทักษะการคิด เด็กที่ฝึกแก้โจทย์เชิงคิดวิเคราะห์เป็นประจำจะได้เปรียบ ส่วนเด็กที่อ่านหนังสือเก่งแต่ไม่ค่อยได้ฝึกคิดในรูปแบบของข้อสอบจะลำบาก ผู้ปกครองควรเตรียมตัวลูกในรูปแบบที่ตรงกับข้อสอบจริง ไม่ใช่เพียงเร่งสอนเนื้อหา ป.1',
  },
  {
    question: 'ควรเริ่มเตรียมสอบเข้าสาธิตจุฬา ป.1 ตอนไหน?',
    answer: 'แนะนำให้เริ่มเตรียมตัวล่วงหน้าอย่างน้อย 6-12 เดือน หรือเริ่มตั้งแต่ลูกอายุประมาณ 4-5 ขวบ ระยะแรกเน้นที่การพัฒนาทักษะพื้นฐาน เช่น การฟังคำสั่ง การสังเกต การจดจ่อ ไม่ต้องเร่งทำข้อสอบจริงทันที พออายุ 5 ขวบครึ่งให้เริ่มทำข้อสอบตัวอย่างทีละน้อย เริ่มจากง่ายไปยาก เพื่อให้เด็กรู้สึกสำเร็จและเกิดความมั่นใจ ในช่วง 3 เดือนสุดท้ายก่อนสอบควรซ้อมจำลองสถานการณ์สอบจริง โดยจับเวลาและใช้รูปแบบกระดาษคำตอบเหมือนของจริง การเริ่มเร็วไม่ได้หมายถึงต้องกดดัน แต่หมายถึงมีเวลาเล่นและเรียนรู้ไปพร้อมกันโดยไม่ต้องอัดติว',
  },
  {
    question: 'สาธิตจุฬารับเด็กกี่คน อัตราการแข่งขันเท่าไหร่?',
    answer: 'สาธิตจุฬาฝ่ายประถมรับนักเรียนเข้าใหม่ ป.1 ในจำนวนที่จำกัด โดยทั่วไปอยู่ในระดับร้อยกว่าคนต่อรุ่น ในขณะที่มีผู้สมัครหลายพันคน อัตราการรับเข้าจึงอยู่ในระดับต่ำ ทำให้การแข่งขันสูงมาก อย่างไรก็ตาม จำนวนรับเข้าที่แน่นอนมักประกาศในระเบียบการรับสมัครของแต่ละปี ผู้ปกครองควรติดตามข้อมูลล่าสุดจากเว็บไซต์สาธิตจุฬาฝ่ายประถมโดยตรง เพื่อให้ได้ตัวเลขที่อัปเดต ระบบคัดเลือกในปัจจุบันมีทั้งการสอบเขียนและการสัมภาษณ์ บางปีอาจมีกิจกรรมประเมินความพร้อมแบบกลุ่มด้วย การเตรียมตัวจึงไม่ใช่แค่เรื่องวิชาการ แต่ต้องเตรียมพฤติกรรมและการเข้าสังคมของเด็กให้พร้อมด้วย',
  },
  {
    question: 'จำเป็นต้องเรียนพิเศษเพื่อสอบเข้าสาธิตจุฬาไหม?',
    answer: 'ไม่จำเป็นต้องเรียนพิเศษราคาแพงเพื่อสอบเข้าสาธิตจุฬา แต่ลูกต้องได้รับการเตรียมตัวอย่างเป็นระบบและคุ้นเคยกับรูปแบบข้อสอบ ผู้ปกครองที่มีเวลาและความเข้าใจสามารถสอนเองได้ที่บ้าน โดยใช้หนังสือฝึกหรือข้อสอบตัวอย่างที่หาได้ทั่วไป หากผู้ปกครองไม่แน่ใจวิธีการสอน หรือไม่มีเวลา การเรียนพิเศษเป็นทางเลือกหนึ่งที่ช่วยให้ลูกได้ฝึกอย่างต่อเนื่องและมีคนชี้แนะ สิ่งสำคัญไม่ใช่ค่าใช้จ่ายแต่เป็นความสม่ำเสมอและการเล่นไปฝึกไปแบบที่เด็กไม่รู้สึกถูกบังคับ SheetSmith ออกแบบเฉลยให้ผู้ปกครองนำไปอ่านสอนลูกเองได้ ไม่จำเป็นต้องมีพื้นฐานการเป็นครู',
  },
  {
    question: 'ถ้าลูกสอบไม่ผ่านสาธิตจุฬาควรทำอย่างไร?',
    answer: 'การสอบไม่ผ่านสาธิตจุฬาไม่ใช่จุดจบของการศึกษาลูก เพราะอัตราการแข่งขันสูงมาก เด็กที่เก่งและพร้อมจำนวนมากก็ยังสอบไม่ผ่านในปีนั้น สิ่งสำคัญคืออย่าให้เด็กรู้สึกว่าตัวเองล้มเหลว ทางเลือกที่ดีคือลองสมัครโรงเรียนสาธิตอื่นที่มีคุณภาพไม่แพ้กัน เช่น สาธิตเกษตร สาธิตประสานมิตร สาธิตพระจอมเกล้าฯ หรือโรงเรียนเอกชนที่มีหลักสูตรเข้มข้น ในระยะยาวคุณภาพการศึกษาขึ้นอยู่กับการเรียนรู้ของเด็กและการดูแลของครอบครัวมากกว่าชื่อโรงเรียน ผู้ปกครองหลายท่านที่ลูกไม่ได้สาธิตจุฬาในชั้น ป.1 สามารถสอบเข้าได้ในระดับ ม.1 หรือ ม.4 หากเตรียมตัวต่อเนื่อง',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบเชาว์ปัญญา (IQ) เข้า ป.1 พร้อมเฉลย', href: '/exams/por1/por1-iq-sample/' },
  { title: 'ตัวอย่างข้อสอบภาษาไทย สาธิตจุฬา ป.1', href: '/exams/por1/por1-satit-chula-thai-sample/' },
  { title: 'ตัวอย่างข้อสอบภาษาอังกฤษ เข้า ป.1', href: '/exams/por1/por1-english-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ป.1 สาธิต ฉบับสมบูรณ์', href: '/guides/how-to-prepare-por1/' },
  { title: 'ข้อสอบเก่าสาธิตจุฬา ป.1 — วิเคราะห์แนวข้อสอบทุกวิชา', href: '/blog/satit-chula-por1-past-exams/' },
  { title: 'สาธิตจุฬา ป.1 ยากแค่ไหน — วิเคราะห์ระดับความยาก', href: '/blog/por1-satit-difficulty/' },
  { title: 'ลูกอายุเท่าไหร่ควรเริ่มเตรียมสอบเข้า ป.1', href: '/blog/when-to-start-por1-prep/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ป.1 สาธิตจุฬา — แนวข้อสอบฟรี พร้อมเฉลยละเอียด',
  description: 'รวมแนวข้อสอบเข้า ป.1 สาธิตจุฬา ครอบคลุมเชาว์ปัญญา ภาษาไทย คณิต อังกฤษ พร้อมเฉลยแบบติวเตอร์ ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/por1/satit-chula/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนสาธิตจุฬาลงกรณ์มหาวิทยาลัย ฝ่ายประถม',
    alternateName: 'สาธิตจุฬา ฝ่ายประถม',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ป.1 สาธิตจุฬา ฟรี พร้อมเฉลยละเอียด 2569"
  description="รวมแนวข้อสอบเข้า ป.1 สาธิตจุฬา ฟรี ครอบคลุมเชาว์ปัญญา ภาษาไทย คณิต อังกฤษ พร้อมเฉลยแบบติวเตอร์ step-by-step เตรียมพร้อมสอบเข้าสาธิตจุฬา ฝ่ายประถม"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ป.1', href: '/exams/por1/' },
      { label: 'สาธิตจุฬา' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ป.1 สาธิตจุฬา — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนสาธิตจุฬาลงกรณ์มหาวิทยาลัย ฝ่ายประถม เป็นหนึ่งในโรงเรียนสาธิตที่มีระดับการแข่งขันสูงที่สุดในประเทศไทย ข้อสอบเข้า ป.1 สาธิตจุฬาไม่ได้เน้นเนื้อหาวิชาการที่ลึก แต่เน้นทดสอบ <strong>ความพร้อมของเด็ก เชาว์ปัญญา และทักษะการคิดเป็นเหตุเป็นผล</strong>
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ป.1 สาธิตจุฬา พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม เพื่อให้ลูกของคุณคุ้นเคยกับรูปแบบข้อสอบจริง และพร้อมเข้าสนามสอบอย่างมั่นใจ
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ป.1 สาธิตจุฬา</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          ข้อสอบเข้า ป.1 สาธิตจุฬาแบ่งเป็นหลายส่วน แต่ละส่วนทดสอบความสามารถที่ต่างกัน วิชาที่สาธิตจุฬาให้น้ำหนักมากที่สุดคือ <strong>เชาว์ปัญญา</strong> และ <strong>ความพร้อม/ทักษะการคิด</strong> เพราะสะท้อนศักยภาพในการเรียนรู้ของเด็ก มากกว่าจะวัดสิ่งที่เด็กท่องจำมาแล้ว
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างแสดงคำถามแนวเชาว์ปัญญาที่พบบ่อยในการสอบเข้า ป.1 สาธิตจุฬา (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (เชาว์ปัญญา — ความสัมพันธ์)</p>
        <p class="text-text-light leading-relaxed">
          "นก สัมพันธ์กับ ฟ้า เหมือน ปลา สัมพันธ์กับ ___?"<br />
          ก. ทะเลทราย ข. น้ำ ค. ต้นไม้ ง. ก้อนหิน
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ถามความสัมพันธ์ระหว่าง "นก-ฟ้า" แล้วเทียบกับ "ปลา-?" ต้องหาคำที่มีความสัมพันธ์ในรูปแบบเดียวกัน</li>
          <li><strong>วิธีคิด</strong> — นกเป็นสัตว์ที่อาศัย/บินอยู่ในฟ้า → ปลาเป็นสัตว์ที่อาศัย/ว่ายอยู่ใน "น้ำ" รูปแบบความสัมพันธ์คือ "สัตว์-ที่อยู่อาศัยตามธรรมชาติ"</li>
          <li><strong>คำตอบ</strong> — ข้อ ข. น้ำ</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กบางคนอาจตอบ "ทะเลทราย" เพราะคิดว่าเป็นที่ที่ปลาไม่อยู่ ตรงข้ามกับนก แต่โจทย์ถามความสัมพันธ์เชิงบวก (ที่อยู่อาศัย) ไม่ใช่ตรงข้าม สอนเด็กว่าให้คิดความสัมพันธ์เป็นรูปแบบเดียวกันเสมอ</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ดาวน์โหลดตัวอย่างข้อสอบเข้า ป.1 สาธิตจุฬา ฟรี</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedSamples.map((s) => (
            <li>
              <a href={s.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {s.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-light mt-4">
          ตัวอย่างทั้งหมดมาพร้อมเฉลยละเอียด ไม่ต้องสมัครสมาชิก เปิดอ่านได้ทันที
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">คู่มือเตรียมสอบและบทความที่เกี่ยวข้อง</h2>
