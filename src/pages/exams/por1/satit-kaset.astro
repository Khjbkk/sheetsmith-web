---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'การสังเกตและธรรมชาติ', icon: '🌿', desc: 'สาธิตเกษตรเน้นทักษะการสังเกต การจำแนกประเภท และความเข้าใจสิ่งแวดล้อมรอบตัว — เด่นกว่าสาธิตอื่นในจุดนี้', emphasis: 'high' },
  { name: 'เชาว์ปัญญา / IQ', icon: '🧠', desc: 'การหาความสัมพันธ์ การจัดประเภท และการคิดเชิงตรรกะ ตามวัย 5-6 ปี', emphasis: 'high' },
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'จำนวนนับ การเปรียบเทียบ รูปทรง และแบบรูปต่อเนื่อง', emphasis: 'normal' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'การฟัง การอ่านคำศัพท์พื้นฐาน และความเข้าใจประโยคในชีวิตประจำวัน', emphasis: 'normal' },
  { name: 'ความพร้อมและพฤติกรรม', icon: '🎯', desc: 'การฟังคำสั่ง การปฏิบัติตามคำแนะนำ การทำงานร่วมกับผู้อื่น', emphasis: 'normal' },
];

const faqItems = [
  {
    question: 'ข้อสอบเข้า ป.1 สาธิตเกษตรต่างจากสาธิตจุฬาอย่างไร?',
    answer: 'ข้อสอบทั้งสองโรงเรียนคล้ายกันในส่วนหลัก คือทั้งคู่ทดสอบเชาว์ปัญญา ความพร้อม และทักษะการคิด แต่สาธิตเกษตรมีจุดเด่นที่เน้น <strong>การสังเกตธรรมชาติและสิ่งแวดล้อม</strong> มากกว่า เพราะวิสัยทัศน์ของโรงเรียนเชื่อมโยงกับมหาวิทยาลัยเกษตรศาสตร์ที่มีจุดเน้นด้านธรรมชาติและการเกษตร ข้อสอบของสาธิตเกษตรจึงมักมีคำถามเกี่ยวกับสัตว์ พืช และวัฏจักรในธรรมชาติ ส่วนสาธิตจุฬาจะเน้นเชาว์ปัญญาเชิงนามธรรมและความสัมพันธ์มากกว่า เด็กที่ชอบเรียนรู้เรื่องธรรมชาติและการสังเกตจะรู้สึกถนัดกับข้อสอบสาธิตเกษตร อย่างไรก็ตามแนะนำให้ฝึกข้อสอบทั้งสองแนวควบคู่ เพราะการสอบหลายโรงเรียนช่วยเพิ่มโอกาส',
  },
  {
    question: 'สาธิตเกษตรรับเด็กกี่คน อัตรารับเข้าสูงกว่าสาธิตจุฬาไหม?',
    answer: 'จำนวนรับเข้า ป.1 ของสาธิตเกษตรอยู่ในระดับร้อยกว่าคนต่อรุ่นเช่นเดียวกับสาธิตจุฬา และมีผู้สมัครจำนวนมากเช่นกัน อัตราการแข่งขันจึงสูงทั้งสองโรงเรียน บางปีสาธิตเกษตรอาจมีอัตราที่นั่งต่อผู้สมัครดีกว่าเล็กน้อย แต่ก็ไม่ได้แตกต่างมากในเชิงสถิติ การประกาศจำนวนรับและกำหนดวันสอบจะอยู่ในระเบียบการรับสมัครของแต่ละปี ผู้ปกครองควรติดตามจากเว็บไซต์ของโรงเรียนสาธิตแห่งมหาวิทยาลัยเกษตรศาสตร์ ศูนย์วิจัยและพัฒนาการศึกษาโดยตรง เพื่อให้ได้ข้อมูลที่อัปเดต ระบบคัดเลือกมักประกอบด้วยการทำข้อสอบและการประเมินความพร้อมแบบกลุ่ม',
  },
  {
    question: 'สาธิตเกษตรสอนเป็นภาษาอังกฤษไหม ลูกต้องเก่งอังกฤษมากแค่ไหน?',
    answer: 'สาธิตเกษตรมีหลักสูตรปกติเป็นภาษาไทยและมีโครงการพิเศษเสริมภาษาอังกฤษ ในระดับ ป.1 ภาษาอังกฤษไม่ใช่วิชาที่ทดสอบหนัก เด็กไม่จำเป็นต้องพูดอ่านอังกฤษคล่อง ระดับที่ต้องการคือรู้จักตัวอักษร A-Z สามารถจำคำศัพท์พื้นฐานในชีวิตประจำวัน เช่น สี ตัวเลข สัตว์ ผลไม้ และมีความคุ้นเคยกับเสียงในการฟัง โรงเรียนต้องการเด็กที่มีพื้นฐานพอจะเรียนรู้ต่อยอดในอนาคต ไม่ได้ต้องการเด็กที่พูดอังกฤษเป็นภาษาแม่ ดังนั้นผู้ปกครองไม่ต้องกังวลเรื่องระดับภาษาอังกฤษมากนัก โฟกัสที่เชาว์ปัญญา ความพร้อม และการสังเกตจะคุ้มกว่า',
  },
  {
    question: 'จะรู้ได้อย่างไรว่าลูกพร้อมสอบสาธิตเกษตร ป.1?',
    answer: 'สัญญาณว่าลูกพร้อมสอบ ป.1 ได้แก่ ทำงานตามคำสั่งหลายขั้นได้ (เช่น "เอาดินสอสีแดงมาเขียนคำตอบในช่องที่ถูก") นั่งสมาธิทำกิจกรรมเดียวได้นาน 20-30 นาที จำตัวเลข 1-20 และตัวอักษรไทย-อังกฤษได้ครบ และสามารถอธิบายความสัมพันธ์ของสิ่งต่างๆ ได้ เช่น บอกว่าทำไมต้นไม้กับนกอยู่ด้วยกัน ทดสอบความพร้อมด้วยการทำข้อสอบตัวอย่าง 1-2 ชุดเต็มภายในเวลาที่กำหนด ถ้าลูกทำได้ครึ่งหนึ่งขึ้นไปและไม่ร้องไห้ระหว่างทำ แสดงว่าพร้อมในแง่ความทนทาน จากนั้นพัฒนาในจุดที่ยังอ่อนต่อจนถึงวันสอบ การทำซ้ำหลายชุดเป็นกุญแจสำคัญ',
  },
  {
    question: 'นอกจากสาธิตเกษตร ป.1 โรงเรียนทางเลือกที่ดีมีอะไรบ้าง?',
    answer: 'นอกจากสาธิตเกษตรแล้ว ผู้ปกครองควรพิจารณาสมัครโรงเรียนสาธิตอื่นเป็นทางเลือกเพื่อเพิ่มโอกาส เช่น สาธิตจุฬา สาธิตประสานมิตร สาธิตปทุมวันฝ่ายประถม และสาธิตของมหาวิทยาลัยอื่นๆ ทั้งกลุ่มนี้มีคุณภาพการสอนใกล้เคียงกัน โรงเรียนเอกชนที่มีระบบการเรียนเข้มข้น เช่น กรุงเทพคริสเตียน อัสสัมชัญ มาแตร์เดอี ก็เป็นทางเลือกที่ผู้ปกครองหลายครอบครัวเลือกควบคู่ การเตรียมข้อสอบเป็นพื้นฐานเดียวกัน เพียงปรับเล็กน้อยตามจุดเน้นของแต่ละโรงเรียน การสมัครหลายที่ช่วยลดความกดดันและเพิ่มโอกาสได้โรงเรียนที่ถูกใจ',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ สาธิตเกษตร ป.1 พร้อมเฉลย', href: '/exams/por1/por1-satit-kaset-math-sample/' },
  { title: 'ตัวอย่างข้อสอบเชาว์ปัญญา (IQ) เข้า ป.1', href: '/exams/por1/por1-iq-sample/' },
  { title: 'ตัวอย่างข้อสอบภาษาอังกฤษ เข้า ป.1', href: '/exams/por1/por1-english-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ป.1 สาธิต ฉบับสมบูรณ์', href: '/guides/how-to-prepare-por1/' },
  { title: 'ข้อสอบเก่าสาธิตเกษตร ป.1 — แนวข้อสอบและเฉลย', href: '/blog/satit-kaset-por1-past-exams/' },
  { title: 'ลูกอายุเท่าไหร่ควรเริ่มเตรียมสอบเข้า ป.1', href: '/blog/when-to-start-por1-prep/' },
  { title: 'วิธีใช้ข้อสอบเก่าให้ได้ผลสูงสุด', href: '/guides/how-to-analyze-past-exams/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ป.1 สาธิตเกษตร — แนวข้อสอบฟรี พร้อมเฉลยละเอียด',
  description: 'รวมแนวข้อสอบเข้า ป.1 สาธิตเกษตร ครอบคลุมการสังเกต เชาว์ปัญญา คณิต อังกฤษ พร้อมเฉลยแบบติวเตอร์ ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/por1/satit-kaset/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนสาธิตแห่งมหาวิทยาลัยเกษตรศาสตร์ ศูนย์วิจัยและพัฒนาการศึกษา',
    alternateName: 'สาธิตเกษตร',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ป.1 สาธิตเกษตร ฟรี พร้อมเฉลยละเอียด 2569"
  description="รวมแนวข้อสอบเข้า ป.1 สาธิตเกษตร ฟรี เน้นการสังเกต เชาว์ปัญญา คณิต ภาษา พร้อมเฉลยแบบติวเตอร์ step-by-step เตรียมสอบเข้าสาธิตเกษตร"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ป.1', href: '/exams/por1/' },
      { label: 'สาธิตเกษตร' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ป.1 สาธิตเกษตร — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนสาธิตแห่งมหาวิทยาลัยเกษตรศาสตร์ ศูนย์วิจัยและพัฒนาการศึกษา (สาธิตเกษตร) เป็นโรงเรียนสาธิตชั้นนำที่มีจุดเด่นด้าน <strong>การสังเกต ธรรมชาติ และการคิดเชิงเหตุผล</strong> ข้อสอบเข้า ป.1 จะเน้นทดสอบความพร้อมและทักษะที่สอดคล้องกับแนวการสอนของโรงเรียน
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ป.1 สาธิตเกษตร พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม ช่วยให้ลูกฝึกในรูปแบบที่ใกล้เคียงกับสนามสอบจริงที่สุด
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ป.1 สาธิตเกษตร</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          ข้อสอบเข้า ป.1 สาธิตเกษตรประกอบด้วยหลายส่วน ส่วนที่มีน้ำหนักสูงเป็นพิเศษคือ <strong>การสังเกตธรรมชาติและสิ่งแวดล้อม</strong> และ <strong>เชาว์ปัญญา</strong> เพราะตรงกับวิสัยทัศน์ของโรงเรียนที่เชื่อมโยงกับมหาวิทยาลัยเกษตรศาสตร์
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างเป็นคำถามแนวการจำแนกประเภทที่พบบ่อยในข้อสอบสาธิตเกษตร ป.1 (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (การจำแนกประเภท)</p>
        <p class="text-text-light leading-relaxed">
          "ข้อใดไม่เข้าพวกกับข้ออื่น?"<br />
          ก. ส้ม ข. กล้วย ค. แอปเปิ้ล ง. รถยนต์
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ให้คำ 4 คำ ต้องหาคำที่ "ไม่เข้าพวก" คือไม่อยู่ในประเภทเดียวกับอีก 3 คำที่เหลือ</li>
          <li><strong>วิธีคิด</strong> — พิจารณาว่า ส้ม กล้วย แอปเปิ้ล เป็นอะไรประเภทเดียวกัน → ทั้ง 3 เป็น "ผลไม้" รถยนต์เป็นยานพาหนะ ดังนั้นรถยนต์คือคำตอบ</li>
          <li><strong>คำตอบ</strong> — ข้อ ง. รถยนต์</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กเล็กบางคนอาจสับสนเพราะดูทุกข้อแล้วทุกอย่างกินได้ ยกเว้นรถยนต์ สอนเด็กให้คิดเป็นขั้น คือ "อะไร 3 อย่างที่เหมือนกัน" ก่อน แล้วค่อยหาตัวที่ไม่เข้ากลุ่ม การจำแนกประเภทเป็นทักษะพื้นฐานของการคิดเชิงตรรกะ ฝึกบ่อยจะเก่งขึ้น</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ดาวน์โหลดตัวอย่างข้อสอบเข้า ป.1 สาธิตเกษตร ฟรี</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedSamples.map((s) => (
            <li>
              <a href={s.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {s.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-light mt-4">
          ตัวอย่างทั้งหมดมาพร้อมเฉลยละเอียด ไม่ต้องสมัครสมาชิก เปิดอ่านได้ทันที
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">คู่มือเตรียมสอบและบทความที่เกี่ยวข้อง</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedReads.map((r) => (
            <li>
              <a href={r.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {r.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <FAQSection title="คำถามที่พบบ่อยเกี่ยวกับการสอบเข้าสาธิตเกษตร ป.1" items={faqItems} />

    <CTABanner
