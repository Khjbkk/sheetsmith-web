---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'พีชคณิตขั้นสูง ฟังก์ชัน ตรีโกณมิติ เรขาคณิต โจทย์ปัญหาประยุกต์ระดับยาก — กุญแจตัดสินการสอบติด', emphasis: 'high' },
  { name: 'ฟิสิกส์', icon: '⚛️', desc: 'กลศาสตร์ การเคลื่อนที่ พลังงาน คลื่น ไฟฟ้า — ทดสอบความเข้าใจหลักการในเชิงปริมาณ', emphasis: 'high' },
  { name: 'เคมี', icon: '🧪', desc: 'อะตอม พันธะเคมี การคำนวณโมล สารละลาย ปฏิกิริยา — ระดับ ม.3 ถึงต้น ม.4', emphasis: 'high' },
  { name: 'ชีววิทยา', icon: '🧬', desc: 'เซลล์ ระบบในร่างกาย พันธุศาสตร์ ระบบนิเวศ ตามหลักสูตร ม.3', emphasis: 'normal' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'Grammar advanced Reading comprehension Vocabulary และ Writing essay', emphasis: 'normal' },
  { name: 'ภาษาไทย-สังคม', icon: '🇹🇭', desc: 'หลักภาษา วรรณคดี สังคมศึกษา ภูมิศาสตร์ ประวัติศาสตร์', emphasis: 'normal' },
];

const faqItems = [
  {
    question: 'ข้อสอบเข้า ม.4 เตรียมอุดมยากแค่ไหน?',
    answer: 'ข้อสอบเข้า ม.4 เตรียมอุดมศึกษา (เตรียมอุดม) เป็นหนึ่งในการสอบที่ยากและการแข่งขันสูงที่สุดของประเทศ <strong>คณิตศาสตร์และวิทยาศาสตร์</strong> เป็นวิชาที่ตัดสินการสอบติด เนื้อหาที่ออกครอบคลุมหลักสูตร ม.1-ม.3 ทั้งหมด และมีข้อยากบางข้อที่ต้องใช้ความเข้าใจระดับ ม.4 ในการแก้ ผู้สมัครหลายคนเป็นเด็กที่ได้คะแนนสูงในระดับ ม.3 มาแล้ว ดังนั้นการแข่งขันคือการแย่งคะแนนเต็มในกลุ่มเด็กเก่ง ในเชิงสถิติ อัตราการรับเข้าสายวิทย์-คณิตของเตรียมอุดมต่ำมาก ผู้สมัครหลายพันคน รับเข้าหลักร้อยถึงพันคน เด็กที่ต้องการติดเตรียมอุดมต้องเตรียมตัว 12-18 เดือนอย่างเข้มข้น มีพื้นฐานคณิต-วิทย์ที่แม่นยำ และฝึกข้อสอบเก่าหลายปี',
  },
  {
    question: 'เตรียมอุดมรับเด็กกี่คนต่อปี?',
    answer: 'จำนวนรับเข้านักเรียนใหม่ ม.4 ของเตรียมอุดมศึกษาแตกต่างกันในแต่ละปี โดยทั่วไปรับนักเรียนใหม่หลายร้อยคน แบ่งตามแผนการเรียน ได้แก่ <strong>วิทย์-คณิต ภาษา-คณิต ภาษา-ภาษา</strong> ในขณะที่ผู้สมัครมีนับหมื่นคน อัตรารับเข้าจึงต่ำมาก สายวิทย์-คณิตมักรับมากที่สุดและมีการแข่งขันสูงสุด เพราะเป็นสายที่นักเรียนส่วนใหญ่เลือกต่อมหาวิทยาลัยในคณะที่มีการแข่งขันสูง เช่น แพทย์ วิศวะ หรือทุนต่างประเทศ จำนวนรับเข้าและเกณฑ์คะแนนของแต่ละปีจะประกาศในระเบียบการรับสมัคร ผู้ปกครองและนักเรียนควรติดตามข้อมูลล่าสุดจากเว็บไซต์เตรียมอุดมโดยตรง การวางแผนสมัครหลายแผนการเรียนช่วยเพิ่มโอกาส',
  },
  {
    question: 'ควรเริ่มเตรียมสอบเข้าเตรียมอุดม ม.4 ตั้งแต่ตอนไหน?',
    answer: 'แนะนำให้เริ่มเตรียมตัวอย่างจริงจังตั้งแต่ <strong>ม.2-ม.3</strong> หรืออย่างน้อย 12-18 เดือนก่อนวันสอบ ระยะแรก (ม.2 ถึงต้น ม.3) ปูพื้นฐานคณิตและวิทยาศาสตร์ให้แม่นยำ โดยทบทวนเนื้อหา ม.1-ม.2 และเรียนรู้เนื้อหา ม.3 ล่วงหน้า ฝึกแก้โจทย์หลากหลายรูปแบบ ในช่วง ม.3 ครึ่งหลังเริ่มทำข้อสอบเข้าจริงจาก SheetSmith และแหล่งอื่น สัปดาห์ละ 2-3 ชุด เน้นวิเคราะห์ข้อที่ทำผิด 6 เดือนสุดท้ายเข้มข้นที่การจับเวลาทำข้อสอบเต็มชุดในเวลาจริง และวิเคราะห์ patterns ข้อสอบเก่าหลายปี การเรียนเสริมเนื้อหา ม.4 ล่วงหน้าในวิชาคณิต-ฟิสิกส์-เคมีก็ช่วยมาก เพราะข้อยากบางข้อต้องใช้ความรู้ระดับ ม.4',
  },
  {
    question: 'จำเป็นต้องเรียนคอร์สเตรียมสอบเตรียมอุดมไหม?',
    answer: 'การเรียนคอร์สเตรียมสอบช่วยได้แต่ไม่ใช่กุญแจสำคัญที่สุด เด็กหลายคนติดเตรียมอุดมด้วยการเรียนในโรงเรียนปกติ + ทำข้อสอบเก่าจำนวนมากด้วยตัวเอง + มีผู้ปกครองหรือพี่ติวเตอร์ส่วนตัวช่วยตอบคำถาม สิ่งที่จำเป็นจริงคือ <strong>การฝึกข้อสอบในปริมาณมาก</strong> (50-100 ชุดก่อนสอบ) และ <strong>การวิเคราะห์ข้อที่ทำผิด</strong> ทุกครั้งเพื่อเรียนรู้ ค่าใช้จ่ายติวเตอร์ราคาแพงไม่ได้รับประกันการสอบติด แต่ใช้เวลาฝึกข้อสอบและมีเฉลยคุณภาพดีรับประกันได้ ผู้ปกครองที่งบจำกัดสามารถใช้แหล่งฟรีคุณภาพดี เช่น ข้อสอบเก่าจาก SheetSmith ที่มีเฉลยแบบติวเตอร์ ก็เพียงพอ ปัจจัยตัดสินคือความสม่ำเสมอและความตั้งใจของเด็กเอง',
  },
  {
    question: 'ถ้าไม่ติดเตรียมอุดม ทางเลือกที่ดีคืออะไร?',
    answer: 'หากไม่ติดเตรียมอุดม ยังมีโรงเรียน ม.ปลายชั้นนำที่มีคุณภาพไม่แพ้กัน <strong>มหิดลวิทยานุสรณ์ (MWIT)</strong> คือทางเลือกอันดับต้นสำหรับสายวิทย์ เป็นโรงเรียนวิทย์ชั้นนำของประเทศและฟรี (มีหอพัก) สายวิทย์-คณิตยังมี เตรียมอุดมศึกษาน้อมเกล้า เตรียมอุดมศึกษาพัฒนาการ บดินทรเดชา สวนกุหลาบ ที่มี ม.ปลายคุณภาพดี โรงเรียนสาธิตทุกแห่ง (สาธิตจุฬา สาธิตเกษตร สาธิตประสานมิตร สาธิตปทุมวัน) ก็มีสายวิทย์-คณิตเข้มข้น สำหรับผู้ที่สนใจหลักสูตรอินเตอร์ มีโรงเรียนนานาชาติและโครงการ EP ในโรงเรียนรัฐและเอกชน คุณภาพการศึกษาระยะยาวขึ้นอยู่กับเด็กและการสนับสนุนของครอบครัวมากกว่าชื่อโรงเรียน นักเรียนหลายคนจากโรงเรียนอื่นสอบเข้าคณะที่มีการแข่งขันสูงได้ดีไม่แพ้เด็กเตรียมอุดม',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ เข้า ม.4 พร้อมเฉลย', href: '/exams/mor4/mor4-math-sample/' },
  { title: 'ตัวอย่างข้อสอบภาษาอังกฤษ เข้า ม.4', href: '/exams/mor4/mor4-english-sample/' },
  { title: 'ตัวอย่างข้อสอบไทย-สังคม ม.4', href: '/exams/mor4/mor4-thai-social-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ม.4 เตรียมอุดม ฉบับสมบูรณ์', href: '/guides/how-to-prepare-mor4/' },
  { title: 'คะแนนตัดสอบเตรียมอุดม ม.4 — สถิติและแนวทาง', href: '/blog/triam-cutoff-score/' },
  { title: 'เปรียบเทียบเตรียมอุดม vs MWIT', href: '/blog/triam-vs-mwit/' },
  { title: 'ข้อสอบเก่าเตรียมอุดม ม.4 — แนวข้อสอบและเฉลย', href: '/blog/past-exam-papers-mor4-triam/' },
  { title: 'ข้อสอบคณิตศาสตร์เตรียมอุดม — เทคนิคและตัวอย่าง', href: '/blog/triam-math-past-exams/' },
  { title: 'ข้อสอบวิทยาศาสตร์เตรียมอุดม', href: '/blog/triam-science-past-exams/' },
  { title: 'ข้อสอบภาษาอังกฤษเตรียมอุดม', href: '/blog/triam-english-past-exams/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ม.4 เตรียมอุดม — แนวข้อสอบฟรี พร้อมเฉลยละเอียด',
  description: 'รวมแนวข้อสอบเข้า ม.4 เตรียมอุดมศึกษา คณิต ฟิสิกส์ เคมี ชีวะ อังกฤษ พร้อมเฉลยแบบติวเตอร์ ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/mor4/triam-udom/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนเตรียมอุดมศึกษา',
    alternateName: 'เตรียมอุดม',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ม.4 เตรียมอุดม ฟรี พร้อมเฉลยละเอียด 2569"
  description="รวมแนวข้อสอบเข้า ม.4 เตรียมอุดมศึกษา ฟรี คณิต ฟิสิกส์ เคมี ชีวะ อังกฤษ พร้อมเฉลยแบบติวเตอร์ step-by-step เตรียมสอบเข้าเตรียมอุดม"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ม.4', href: '/exams/mor4/' },
      { label: 'เตรียมอุดม' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ม.4 เตรียมอุดม — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนเตรียมอุดมศึกษา (เตรียมอุดม) เป็นโรงเรียนมัธยมศึกษาตอนปลายที่มีชื่อเสียงและการแข่งขันสูงที่สุดของประเทศไทย ข้อสอบเข้า ม.4 เน้น <strong>คณิตศาสตร์ ฟิสิกส์ และเคมี</strong> ในระดับยาก เพื่อคัดเลือกนักเรียนที่มีศักยภาพในสายวิทย์-คณิตและสายภาษา-คณิต
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ม.4 เตรียมอุดม พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม ครอบคลุมวิชาหลักที่ออกสอบจริง
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ม.4 เตรียมอุดม</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          ข้อสอบเข้า ม.4 เตรียมอุดมแบ่งตามแผนการเรียนที่สมัคร โดยมี <strong>วิทย์-คณิต ภาษา-คณิต และภาษา-ภาษา</strong> สายวิทย์-คณิตมีการแข่งขันสูงสุดและคะแนนตัดสูงที่สุด เนื้อหาคณิต-ฟิสิกส์-เคมีระดับ ม.3 ถึงต้น ม.4 ออกค่อนข้างยากเพื่อคัดเลือกเด็กที่พร้อมเรียน ม.ปลายสายวิทย์
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างเป็นโจทย์คณิตศาสตร์แนวที่พบบ่อยในข้อสอบเข้า ม.4 เตรียมอุดม (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (พีชคณิต — การยกกำลังสอง)</p>
        <p class="text-text-light leading-relaxed">
          ถ้า x + 1/x = 4 จงหาค่าของ x² + 1/x²
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ให้ค่าของ "x + 1/x" และถามค่าของ "x² + 1/x²" ทั้งสองนิพจน์มีความสัมพันธ์กันผ่านการยกกำลังสอง</li>
          <li><strong>วิธีคิด — ยกกำลังสอง</strong> — จากสมการ x + 1/x = 4 ยกกำลังสองทั้งสองข้าง: (x + 1/x)² = 4² = 16</li>
          <li><strong>กระจายด้านซ้าย</strong> — (x + 1/x)² = x² + 2·x·(1/x) + (1/x)² = x² + 2 + 1/x²</li>
          <li><strong>จัดสมการ</strong> — x² + 2 + 1/x² = 16 → x² + 1/x² = 14</li>
          <li><strong>คำตอบ</strong> — x² + 1/x² = 14</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กบางคนพลาดเพราะจำสูตร (a+b)² = a² + b² ผิด ลืม 2ab ตรงกลาง สอนเด็กให้กระจายเองทุกครั้งจนคล่อง สูตรนี้ใช้ได้กับโจทย์อีกหลายรูปแบบ เช่น ถ้าให้ x + y และ x² + y² หรือถ้าให้ x − 1/x และ x² + 1/x² เทคนิคเดียวกัน — ยกกำลังสองแล้วจัดให้ได้คำตอบ การฝึกแบบนี้ซ้ำๆ ช่วยให้ทำข้อสอบเร็วขึ้น</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
