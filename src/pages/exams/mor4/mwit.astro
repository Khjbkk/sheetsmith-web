---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'พีชคณิตขั้นสูง ตรีโกณ ฟังก์ชัน เรขาคณิต โจทย์ปัญหาระดับโอลิมปิก — กุญแจตัดสินรอบแรก', emphasis: 'high' },
  { name: 'ฟิสิกส์', icon: '⚛️', desc: 'กลศาสตร์ พลังงาน คลื่น ไฟฟ้า ระดับ ม.4-ม.5 — MWIT ให้น้ำหนักมากที่สุด', emphasis: 'high' },
  { name: 'เคมี', icon: '🧪', desc: 'อะตอม พันธะ การคำนวณโมล สมดุล ปฏิกิริยา ระดับ ม.4 ขึ้นไป', emphasis: 'high' },
  { name: 'ชีววิทยา', icon: '🧬', desc: 'เซลล์ ระบบในร่างกาย พันธุศาสตร์ ระบบนิเวศ ระดับ ม.3-ม.4', emphasis: 'high' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'Reading scientific text Vocabulary และ Grammar advanced ใช้สำหรับเรียนวิทย์เป็นภาษาอังกฤษ', emphasis: 'normal' },
];

const faqItems = [
  {
    question: 'MWIT คืออะไร ต่างจากเตรียมอุดมยังไง?',
    answer: 'MWIT คือ <strong>โรงเรียนมหิดลวิทยานุสรณ์ (Mahidol Wittayanusorn School)</strong> เป็นโรงเรียนวิทยาศาสตร์ระดับชั้นนำที่สุดของประเทศไทย เป็นโรงเรียน <strong>ประจำมีหอพัก ไม่มีค่าเล่าเรียน</strong> และรับเฉพาะนักเรียนสายวิทย์-คณิต ม.4-ม.6 จุดที่ต่างจากเตรียมอุดมคือ MWIT มีจำนวนรับเข้าน้อยมาก (ประมาณ 240 คนต่อรุ่น) เป็นโรงเรียนเดียวที่เน้น "วิทย์ลึก" และมีหลักสูตรเทียบเท่าโรงเรียนวิทย์ของประเทศชั้นนำในโลก เช่น Singapore Math+Sci, NTU+SUTD high schools เด็กที่ติด MWIT ได้รับการคัดเลือกเพื่อเข้าทีมโอลิมปิกชาติไทยจำนวนมาก หลายคนได้ทุนเรียนต่อต่างประเทศ ส่วนเตรียมอุดมเป็นโรงเรียนมัธยมปกติที่มีหลายสาย รับนักเรียนมากกว่า และไม่ใช่โรงเรียนประจำ',
  },
  {
    question: 'ข้อสอบเข้า MWIT ยากกว่าเตรียมอุดมไหม?',
    answer: 'ข้อสอบเข้า MWIT ยากกว่าเตรียมอุดมในเชิงความซับซ้อนของเนื้อหา เพราะ MWIT คัดเลือกเด็กที่จะเรียนวิทย์ในระดับลึกมาก ข้อสอบจึงมีคำถามแนวโอลิมปิกระดับชาติ ต้องใช้ความเข้าใจหลักการลึกและการคิดสร้างสรรค์ในการแก้ปัญหา การสอบ MWIT แบ่งเป็น <strong>2 รอบ</strong> — รอบแรกเป็นข้อสอบปรนัยและอัตนัยเพื่อคัดเลือกผู้มีคุณสมบัติ รอบสองเป็นข้อสอบเข้มข้นและการสัมภาษณ์เพื่อเลือกผู้ที่ผ่าน เด็กที่ผ่านรอบแรกได้แล้วยังต้องเตรียมตัวสำหรับรอบสองอีก ในขณะที่เตรียมอุดมมีการสอบครั้งเดียว เด็กที่ติดได้ทั้ง MWIT และเตรียมอุดมในปีเดียวกัน มักเลือก MWIT เพราะหลักสูตรเข้มข้นกว่า แต่ MWIT อยู่ที่ปริมณฑล ขณะที่เตรียมอุดมอยู่ใจกลางกรุงเทพ',
  },
  {
    question: 'MWIT รับเด็กกี่คน ใครเหมาะที่จะสอบ?',
    answer: 'MWIT รับนักเรียนใหม่ ม.4 ประมาณ <strong>240 คนต่อปี</strong> ในขณะที่มีผู้สมัครจำนวนมาก ทำให้อัตราการรับเข้าต่ำมาก เด็กที่เหมาะสมจะสอบ MWIT คือเด็กที่ <strong>หลงใหลในวิทยาศาสตร์อย่างแท้จริง</strong> ไม่ใช่แค่อยากเข้าโรงเรียนชื่อดัง เพราะ MWIT เน้นการเรียนลึกและการวิจัย เด็กที่ไม่ชอบวิทย์จะรู้สึกเหนื่อยและไม่มีความสุขแม้ติด ลักษณะของเด็กที่เหมาะ ได้แก่ มีพื้นฐานคณิต-วิทย์แข็งแรงตั้งแต่ ม.ต้น มีประสบการณ์เข้าค่ายวิทย์ โอลิมปิก หรือทำโครงงานวิทย์ มีความสามารถในการเรียนรู้ด้วยตนเอง พร้อมอยู่หอพัก และมีเป้าหมายเรียนต่อด้านวิทยาศาสตร์ วิศวกรรม หรือแพทยศาสตร์ ผู้ปกครองที่ต้องการให้ลูกเข้า MWIT ควรประเมินความต้องการของลูกก่อนผลักดัน',
  },
  {
    question: 'ควรเริ่มเตรียมสอบ MWIT ตั้งแต่ตอนไหน?',
    answer: 'เด็กที่ติด MWIT ส่วนใหญ่เริ่มเตรียมตัวอย่างจริงจังตั้งแต่ <strong>ม.1-ม.2</strong> เพราะข้อสอบต้องใช้ความรู้และทักษะที่สะสมมาเป็นปี การเรียนเสริมเนื้อหา ม.ปลาย ตั้งแต่ ม.ต้น เป็นเรื่องปกติของเด็กกลุ่มนี้ การเข้าค่ายโอลิมปิกวิชาการ หรือเข้าร่วมการแข่งขันวิทย์-คณิต ช่วยเตรียมพื้นฐานและความคิดเชิงวิทยาศาสตร์ ในช่วง ม.3 เน้นทำข้อสอบเก่า MWIT จำนวนมาก (50-100 ชุด) สลับกับการเรียนเสริมเนื้อหา ม.4 ในวิชาคณิต-ฟิสิกส์-เคมี เด็กที่เริ่มเตรียมตัวจริงจังตอน ม.3 อาจรู้สึกว่าเวลาน้อยเกินไป แต่ก็ยังพอเป็นไปได้หากเริ่มอย่างเข้มข้น สิ่งสำคัญคือคุณภาพการเรียนรู้ ไม่ใช่ปริมาณเวลา การมีติวเตอร์หรือพี่ที่เคยติด MWIT ให้คำปรึกษาช่วยมาก',
  },
  {
    question: 'MWIT เสียค่าใช้จ่ายไหม คุ้มที่จะสอบไหม?',
    answer: 'MWIT เป็นโรงเรียนของรัฐในกำกับ <strong>ไม่เสียค่าเล่าเรียน</strong> มีหอพักให้ฟรี ค่าใช้จ่ายส่วนตัวอยู่ในระดับต่ำมากเมื่อเทียบกับโรงเรียนเอกชนหรือโรงเรียนนานาชาติที่มีคุณภาพการสอนใกล้เคียงกัน ในแง่ความคุ้มค่า MWIT เป็น <strong>ทุนการศึกษาที่ดีที่สุดในประเทศ</strong> สำหรับเด็กที่รักวิทย์ เพราะได้เรียนกับครูคุณภาพสูง ทรัพยากรห้องแลปและอุปกรณ์ดีระดับมหาวิทยาลัย เพื่อนร่วมรุ่นเก่งและทุนใจดี และโอกาสได้รับทุนเรียนต่อต่างประเทศ การเรียน MWIT ไม่เหมาะกับทุกคน เด็กที่ไม่ชอบวิทย์ อยู่บ้านได้ไม่ดี หรือต้องการเรียนสายอื่น MWIT อาจไม่คุ้ม สำหรับเด็กที่รักวิทย์และพร้อมเรียนเข้มข้น MWIT คือทางลัดสู่อาชีพในสายวิทยาศาสตร์และเทคโนโลยีระดับโลก',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบ MWIT ม.4 — คณิต-วิทย์ พร้อมเฉลย', href: '/exams/mor4/mor4-mwit-sample/' },
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ เข้า ม.4', href: '/exams/mor4/mor4-math-sample/' },
  { title: 'ตัวอย่างข้อสอบวิทยาศาสตร์ EP เข้า ม.4', href: '/exams/mor4/mor4-science-ep-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ม.4 ฉบับสมบูรณ์', href: '/guides/how-to-prepare-mor4/' },
  { title: 'ข้อสอบ MWIT รอบแรก vs รอบสอง — เปรียบเทียบ', href: '/blog/mwit-round1-vs-round2/' },
  { title: 'คู่มือข้อสอบเก่า MWIT — แนวข้อสอบและเทคนิค', href: '/blog/mwit-past-exams-guide/' },
  { title: 'เปรียบเทียบเตรียมอุดม vs MWIT', href: '/blog/triam-vs-mwit/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ม.4 มหิดลวิทยานุสรณ์ (MWIT) — แนวข้อสอบฟรี พร้อมเฉลย',
  description: 'รวมแนวข้อสอบเข้า ม.4 MWIT คณิต ฟิสิกส์ เคมี ชีวะระดับสูง พร้อมเฉลยแบบติวเตอร์ ทั้งรอบแรกและรอบสอง ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/mor4/mwit/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนมหิดลวิทยานุสรณ์',
    alternateName: 'MWIT',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ม.4 MWIT (มหิดลวิทยานุสรณ์) ฟรี พร้อมเฉลย 2569"
  description="รวมแนวข้อสอบเข้า ม.4 มหิดลวิทยานุสรณ์ MWIT ฟรี คณิต ฟิสิกส์ เคมี ชีวะระดับสูง พร้อมเฉลยแบบติวเตอร์ ทั้งรอบแรกและรอบสอง"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ม.4', href: '/exams/mor4/' },
      { label: 'MWIT (มหิดลวิทยานุสรณ์)' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ม.4 MWIT มหิดลวิทยานุสรณ์ — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนมหิดลวิทยานุสรณ์ (MWIT — Mahidol Wittayanusorn School) เป็นโรงเรียนวิทยาศาสตร์ระดับชั้นนำของประเทศ <strong>ไม่มีค่าเล่าเรียน มีหอพักให้ฟรี</strong> รับเฉพาะนักเรียนสายวิทย์-คณิต ม.4-ม.6 จำนวนรับเข้าจำกัด ทำให้การสอบเข้ามีการแข่งขันสูง
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ม.4 MWIT ทั้งรอบแรกและรอบสอง พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม ช่วยเตรียมความพร้อมในระดับเข้มข้นที่ MWIT ต้องการ
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ม.4 MWIT</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          การสอบเข้า MWIT แบ่งเป็น 2 รอบ <strong>รอบแรก</strong> ทดสอบความรู้พื้นฐานคณิต-วิทย์ระดับ ม.3-ม.4 ในรูปแบบปรนัยและอัตนัย <strong>รอบสอง</strong> เป็นการสอบเข้มข้นมากขึ้น บวกการสัมภาษณ์เพื่อประเมินความเหมาะสมกับการเรียนแบบประจำและความมุ่งมั่นในสายวิทย์
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างเป็นโจทย์ฟิสิกส์การเคลื่อนที่ที่พบบ่อยในข้อสอบเข้า MWIT รอบแรก (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (ฟิสิกส์ — การตกอย่างอิสระ)</p>
        <p class="text-text-light leading-relaxed">
          วัตถุตกจากที่สูง 80 เมตรอย่างอิสระ (ไม่มีแรงต้านอากาศ) ใช้เวลากี่วินาทีจึงถึงพื้น? (กำหนด g = 10 m/s²)
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ให้ความสูง 80 เมตร ค่า g = 10 m/s² ความเร็วต้น 0 (ตกอย่างอิสระ = ปล่อยจากนิ่ง) ถามเวลาที่ตกถึงพื้น</li>
          <li><strong>เลือกสูตร</strong> — สูตรการตกอย่างอิสระจากนิ่ง: h = ½ · g · t² (เพราะ u = 0 ความเร็วต้นเป็นศูนย์)</li>
          <li><strong>แทนค่า</strong> — 80 = ½ · 10 · t² = 5 · t²</li>
          <li><strong>แก้สมการหา t</strong> — t² = 80 ÷ 5 = 16 → t = √16 = 4 วินาที</li>
          <li><strong>คำตอบ</strong> — t = 4 วินาที</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กบางคนใช้สูตร h = g · t (ผิด) เพราะลืม ½ และลืมยกกำลังสอง t สอนเด็กว่าให้จดจำ "การตกอย่างอิสระจากนิ่ง = ½gt²" เป็นสูตรพื้นฐานที่ต้องเชี่ยวชาญ ในข้อสอบ MWIT รอบแรกข้อแบบนี้ออกเสมอ ระดับความยากเพิ่มขึ้นในรอบสอง เช่น เปลี่ยนเป็นวัตถุที่มีความเร็วต้น หรือมีแรงต้านอากาศที่ต้องคิด หรือเป็นการเคลื่อนที่ในแนวระดับ การฝึกโจทย์การเคลื่อนที่ครบทุกรูปแบบเป็นพื้นฐานที่ต้องแม่นยำ</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ดาวน์โหลดตัวอย่างข้อสอบเข้า ม.4 MWIT ฟรี</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedSamples.map((s) => (
            <li>
              <a href={s.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {s.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-light mt-4">
