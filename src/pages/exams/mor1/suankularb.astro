---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'พีชคณิตเบื้องต้น เรขาคณิต สมการ พื้นที่ และโจทย์ปัญหาประยุกต์ — สวนกุหลาบให้น้ำหนักสูงมาก', emphasis: 'high' },
  { name: 'วิทยาศาสตร์', icon: '🔬', desc: 'ฟิสิกส์ เคมี ชีววิทยา ระดับ ม.ต้น เน้นเข้าใจหลักการมากกว่าท่องจำ', emphasis: 'high' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'Grammar tense คำศัพท์ การอ่านจับใจความ และการเขียนประโยค', emphasis: 'normal' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'คำศัพท์ ไวยากรณ์ การอ่านจับใจความ และวรรณคดี ป.6-ม.1', emphasis: 'normal' },
  { name: 'สังคมศึกษา', icon: '🌏', desc: 'ภูมิศาสตร์ ประวัติศาสตร์ หน้าที่พลเมือง เศรษฐศาสตร์เบื้องต้น', emphasis: 'normal' },
];

const faqItems = [
  {
    question: 'ข้อสอบเข้า ม.1 สวนกุหลาบยากแค่ไหน?',
    answer: 'ข้อสอบเข้า ม.1 สวนกุหลาบวิทยาลัยมีความยากในระดับสูงเทียบกับโรงเรียนชั้นนำอื่นๆ ในกรุงเทพ จุดที่ทำให้ข้อสอบนี้ท้าทายคือ <strong>คณิตศาสตร์</strong> และ <strong>วิทยาศาสตร์</strong> ที่มักออกข้อที่ต้องคิดต่อยอด ไม่ใช่แค่ท่องสูตร นักเรียน ป.6 ที่เรียนตามหลักสูตรปกติอาจรู้สึกว่าข้อสอบเกินระดับชั้น เพราะข้อยากๆ ต้องใช้ความเข้าใจระดับ ม.1-ม.2 มาช่วย เด็กที่ต้องการสอบติดสวนกุหลาบจึงต้องเรียนเสริมเนื้อหาที่ก้าวหน้ากว่าระดับชั้น และฝึกข้อสอบเก่าหลายปี การมีพื้นฐานทางคณิตศาสตร์ที่แข็งแรงและความถนัดในการคิดเชิงตรรกะจะได้เปรียบ แต่อย่ากลัวจนเกินไป — เด็กหลายคนที่เริ่มเตรียมตัวอย่างจริงจัง 6-12 เดือนก่อนสอบสามารถพิชิตได้',
  },
  {
    question: 'สวนกุหลาบรับเด็กชายหรือชายหญิงรวมกัน?',
    answer: 'โรงเรียนสวนกุหลาบวิทยาลัยเป็น <strong>โรงเรียนชายล้วน</strong> ในระดับมัธยมศึกษาตอนต้น (ม.1-ม.3) มีประวัติยาวนานตั้งแต่ปี 2425 ในฐานะโรงเรียนชายชั้นนำของประเทศ การสอบเข้า ม.1 จึงเปิดรับเฉพาะนักเรียนชาย โรงเรียนในเครือสวนกุหลาบที่รับเด็กหญิงด้วยมี เช่น สวนกุหลาบวิทยาลัย นนทบุรี และสวนกุหลาบวิทยาลัย เพชรเกษม ที่เป็นโรงเรียนสหศึกษา หากผู้ปกครองมีลูกสาว สามารถพิจารณาสาขาในเครือสวนกุหลาบ หรือสาธิตปทุมวัน สาธิตประสานมิตร เตรียมอุดมศึกษาพัฒนาการ บดินทรเดชา ที่รับนักเรียนหญิงเข้า ม.1 และมีคุณภาพไม่แพ้กัน',
  },
  {
    question: 'ควรเริ่มเตรียมสอบเข้าสวนกุหลาบตั้งแต่ตอนไหน?',
    answer: 'แนะนำให้เริ่มเตรียมตัวอย่างจริงจังตั้งแต่ <strong>ป.5</strong> เพื่อให้มีเวลา 12-18 เดือนในการพัฒนาเนื้อหาคณิตและวิทย์ให้ก้าวหน้ากว่าหลักสูตรปกติ ในระยะแรก (ป.5 เทอม 1-2) เน้นปูพื้นฐานให้แม่นยำ โดยเฉพาะคณิตศาสตร์ที่เป็นกุญแจสู่การติดสวนกุหลาบ พอเข้า ป.6 ให้เริ่มฝึกข้อสอบจริงจาก SheetSmith และแหล่งอื่น สลับกับการเรียนเสริมเนื้อหา ม.1 ในวิชาคณิต-วิทย์ ในช่วง 3 เดือนสุดท้ายควรซ้อมจับเวลาทำข้อสอบเต็มชุด สัปดาห์ละ 1-2 ชุด เพื่อให้คุ้นกับสภาวะกดดันในวันสอบ การเริ่มเร็วช่วยให้ลูกไม่ต้องเหนื่อยอัดติวช่วงท้าย และมีเวลาแก้จุดอ่อนเฉพาะ',
  },
  {
    question: 'จำเป็นต้องเรียนติวเตอร์เฉพาะเพื่อสอบเข้าสวนกุหลาบไหม?',
    answer: 'ไม่จำเป็นต้องเรียนติวเตอร์ที่ราคาแพง แต่จำเป็นต้องมีแหล่งฝึกข้อสอบที่ดีและมีคนชี้แนะเวลาติดปัญหา ผู้ปกครองที่มีเวลาและความรู้สามารถสอนเองได้ในวิชาคณิตและไทย ส่วนวิชาวิทย์-อังกฤษอาจต้องใช้ทรัพยากรเสริม เช่น ติวออนไลน์ หนังสือเรียน หรือกลุ่มเรียนเล็ก ค่าใช้จ่ายไม่ใช่ปัจจัยตัดสินผลสอบ — ปัจจัยจริงคือความสม่ำเสมอ ปริมาณข้อสอบที่ทำ และคุณภาพของเฉลย เด็กที่ทำข้อสอบจริง 30-50 ชุดก่อนสอบและเข้าใจวิธีคิดของแต่ละข้อ มักทำคะแนนได้ดีกว่าเด็กที่เรียนติวเตอร์ราคาแพงแต่ทำข้อสอบน้อย SheetSmith มีเฉลยแบบติวเตอร์ทุกข้อ ผู้ปกครองสามารถใช้สอนลูกได้โดยไม่ต้องเป็นครู',
  },
  {
    question: 'ถ้าสอบไม่ติดสวนกุหลาบ มีโรงเรียนชายอื่นที่ดีไหม?',
    answer: 'แม้สอบไม่ติดสวนกุหลาบ ยังมีโรงเรียนชายที่มีคุณภาพไม่แพ้กัน เช่น <strong>เทพศิรินทร์</strong> ที่เป็นโรงเรียนชายล้วนเก่าแก่และมีระบบการเรียนเข้มข้น โรงเรียนเซนต์คาเบรียล กรุงเทพคริสเตียน อัสสัมชัญ (ในเครือ Brothers of St. Gabriel) เป็นทางเลือกเอกชนที่เด่นด้านวิชาการและภาษาอังกฤษ โรงเรียนวัดสุทธิวรารามและบดินทรเดชาก็มีคุณภาพดีและรับนักเรียนชาย คุณภาพการศึกษาในระยะยาวขึ้นอยู่กับเด็กเองและการสนับสนุนของครอบครัวมากกว่าชื่อโรงเรียน หลายครอบครัวที่ลูกชายไม่ได้สวนกุหลาบใน ม.1 สามารถสอบเข้าสวนกุหลาบ ม.4 ได้ในภายหลังเมื่อเตรียมตัวเพิ่ม การวางแผนการศึกษาระยะยาวสำคัญกว่าการติดโรงเรียนใดเป็นพิเศษ',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบเข้า ม.1 สวนกุหลาบ — คณิต-วิทย์ พร้อมเฉลย', href: '/exams/mor1/mor1-suankularb-sample/' },
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ ม.1 ระดับสูง พร้อมเฉลย', href: '/exams/mor1/mor1-math-advanced-sample/' },
  { title: 'ตัวอย่างข้อสอบวิทยาศาสตร์ เข้า ม.1', href: '/exams/mor1/mor1-science-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ม.1 โรงเรียนชั้นนำ ฉบับสมบูรณ์', href: '/guides/how-to-prepare-mor1/' },
  { title: 'วิเคราะห์ข้อสอบสวนกุหลาบ 2568', href: '/blog/suankularb-exam-analysis-2568/' },
  { title: 'ข้อสอบเก่าสวนกุหลาบ ม.1 — เทคนิคและเฉลย', href: '/blog/suankularb-past-exams/' },
  { title: 'เทคนิคเตรียมสอบคณิต ม.1', href: '/blog/math-tips-mor1/' },
  { title: 'โรงเรียนชั้นนำสอบเข้า ม.1 ในกรุงเทพ', href: '/blog/top-schools-mor1-bangkok/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ม.1 สวนกุหลาบ — แนวข้อสอบฟรี พร้อมเฉลยละเอียด',
  description: 'รวมแนวข้อสอบเข้า ม.1 สวนกุหลาบวิทยาลัย คณิต-วิทย์ระดับสูง พร้อมเฉลยแบบติวเตอร์ ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/mor1/suankularb/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนสวนกุหลาบวิทยาลัย',
    alternateName: 'สวนกุหลาบ',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ม.1 สวนกุหลาบ ฟรี พร้อมเฉลยละเอียด 2569"
  description="รวมแนวข้อสอบเข้า ม.1 สวนกุหลาบวิทยาลัย ฟรี เน้นคณิต-วิทย์ระดับสูง พร้อมเฉลยแบบติวเตอร์ step-by-step เตรียมสอบเข้าสวนกุหลาบ"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ม.1', href: '/exams/mor1/' },
      { label: 'สวนกุหลาบ' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ม.1 สวนกุหลาบ — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนสวนกุหลาบวิทยาลัย ก่อตั้งปี 2425 เป็นโรงเรียนชายล้วนเก่าแก่และมีคุณภาพการศึกษาระดับชั้นนำของประเทศ ข้อสอบเข้า ม.1 สวนกุหลาบมีระดับความยากสูง โดยเฉพาะ <strong>วิชาคณิตศาสตร์และวิทยาศาสตร์</strong> ที่มักออกข้อที่ต้องคิดต่อยอดเกินระดับ ป.6
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ม.1 สวนกุหลาบ พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม ช่วยให้ลูกของคุณได้ฝึกในรูปแบบที่ตรงกับข้อสอบจริงและมั่นใจในวันสอบ
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ม.1 สวนกุหลาบ</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          ข้อสอบเข้า ม.1 สวนกุหลาบครอบคลุม 5 วิชาหลัก โดยมี <strong>คณิตศาสตร์และวิทยาศาสตร์</strong> เป็นวิชาที่ทำคะแนนได้แต่งต่างมากที่สุดระหว่างผู้สมัคร เด็กที่ต้องการคะแนนสูงต้องเข้มข้นในสองวิชานี้เป็นพิเศษ
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างเป็นโจทย์คณิตศาสตร์แนวที่พบบ่อยในข้อสอบเข้า ม.1 สวนกุหลาบ (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (คณิตศาสตร์ — โจทย์ปัญหาเปอร์เซ็นต์)</p>
        <p class="text-text-light leading-relaxed">
          นักเรียนชั้น ม.1 ของโรงเรียนแห่งหนึ่งมีทั้งหมด 240 คน เป็นนักเรียนชาย 60% ที่เหลือเป็นนักเรียนหญิง จำนวนนักเรียนชายและหญิงต่างกันกี่คน?
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ให้จำนวนรวม (240) และเปอร์เซ็นต์ของชาย (60%) ถามผลต่างระหว่างชายกับหญิง ไม่ใช่จำนวนชาย/หญิง</li>
          <li><strong>คำนวณจำนวนชาย</strong> — 60% ของ 240 = (60 × 240) ÷ 100 = 144 คน</li>
          <li><strong>คำนวณจำนวนหญิง</strong> — ที่เหลือ = 240 − 144 = 96 คน (หรือคิดจาก 40% ของ 240 = 96 ก็ได้)</li>
          <li><strong>หาผลต่าง</strong> — 144 − 96 = 48 คน</li>
          <li><strong>คำตอบ</strong> — ชายมากกว่าหญิง 48 คน</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กหลายคนพลาดเพราะตอบจำนวนชายหรือจำนวนหญิงโดยไม่ได้หาผลต่าง สอนเด็กให้ขีดเส้นใต้คำว่า "ต่างกัน" ในโจทย์ก่อนเริ่มคิด เพื่อจำว่าต้องตอบอะไรกันแน่</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ดาวน์โหลดตัวอย่างข้อสอบเข้า ม.1 สวนกุหลาบ ฟรี</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedSamples.map((s) => (
            <li>
              <a href={s.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {s.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-light mt-4">
          ตัวอย่างทั้งหมดมาพร้อมเฉลยละเอียด ไม่ต้องสมัครสมาชิก เปิดอ่านได้ทันที
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">คู่มือเตรียมสอบและบทความที่เกี่ยวข้อง</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedReads.map((r) => (
            <li>
              <a href={r.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {r.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

