---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ExamCard from '../../../components/ExamCard.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const exams = (await getCollection('exams', ({ data }) => data.publishDate <= new Date()))
  .filter((e) => e.data.level === 'mor1')
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const freeExams = exams.filter((e) => e.data.isFree);

const subjects = [
  { name: 'คณิตศาสตร์', icon: '📐', desc: 'จำนวนจริง สมการ เรขาคณิต สถิติ' },
  { name: 'วิทยาศาสตร์', icon: '🔬', desc: 'ชีววิทยา เคมี ฟิสิกส์ โลกและอวกาศ' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'Grammar, Reading, Vocabulary, Writing' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'หลักภาษา วรรณคดี การอ่านจับใจความ' },
  { name: 'สังคมศึกษา', icon: '🌏', desc: 'ประวัติศาสตร์ ภูมิศาสตร์ หน้าที่พลเมือง' },
];

const faqItems = [
  {
    question: 'สอบเข้า ม.1 โรงเรียนชั้นนำสอบวิชาอะไรบ้าง?',
    answer: 'โรงเรียนชั้นนำส่วนใหญ่สอบ 5 วิชาหลัก ได้แก่ คณิตศาสตร์ วิทยาศาสตร์ ภาษาอังกฤษ ภาษาไทย และสังคมศึกษา บางโรงเรียนอาจมีการสอบสัมภาษณ์หรือทดสอบทักษะพิเศษเพิ่มเติม',
  },
  {
    question: 'ข้อสอบเข้า ม.1 สาธิตปทุมวันยากแค่ไหน?',
    answer: 'ข้อสอบเข้า ม.1 สาธิตปทุมวันมีความยากปานกลางถึงสูง โดยเฉพาะวิชาคณิตศาสตร์และวิทยาศาสตร์ที่มักมีข้อสอบประยุกต์ การฝึกทำข้อสอบหลายชุดจะช่วยให้คุ้นเคยกับรูปแบบและระดับความยาก',
  },
  {
    question: 'ควรเริ่มเตรียมสอบเข้า ม.1 ตั้งแต่เมื่อไหร่?',
    answer: 'แนะนำให้เริ่มเตรียมตัวตั้งแต่ ป.5 หรืออย่างน้อย 1 ปีก่อนสอบ ช่วง ป.5 ควรเริ่มปูพื้นฐานให้แน่น พอ ป.6 จะได้เน้นฝึกทำข้อสอบและทบทวนจุดอ่อน',
  },
  {
    question: 'สอบเข้า ม.1 สวนกุหลาบต้องเตรียมอะไรบ้าง?',
    answer: 'สวนกุหลาบวิทยาลัยสอบ 5 วิชาหลัก โดยเน้นคณิตศาสตร์และวิทยาศาสตร์เป็นพิเศษ ควรฝึกทำข้อสอบแนว competitive math และวิทยาศาสตร์ประยุกต์ให้คล่อง',
  },
];
---

<BaseLayout
  title="ข้อสอบเข้า ม.1 — รวมแนวข้อสอบสาธิตปทุมวัน สวนกุหลาบ โรงเรียนชั้นนำ"
  description="รวมตัวอย่างข้อสอบเข้า ม.1 พร้อมเฉลยละเอียด แนวข้อสอบคณิต วิทย์ อังกฤษ ไทย สังคม สำหรับเตรียมสอบเข้าโรงเรียนชั้นนำ"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ม.1' },
    ]} />

    <header class="mb-12">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ม.1 — รวมแนวข้อสอบสาธิตปทุมวัน สวนกุหลาบ โรงเรียนชั้นนำ
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          การสอบเข้า ม.1 ของโรงเรียนชั้นนำอย่างสาธิตปทุมวัน สวนกุหลาบวิทยาลัย เตรียมอุดมพัฒนาการ และโรงเรียนดังอื่นๆ มีการแข่งขันสูง นักเรียนต้องมีความรู้พื้นฐานที่แน่นและสามารถประยุกต์ใช้ในการแก้โจทย์ได้
        </p>
        <p>
          SheetSmith รวบรวมแนวข้อสอบจากสนามสอบจริง ครบทุกวิชา พร้อมเฉลยละเอียดที่อธิบายวิธีคิดทุกข้อ ช่วยให้นักเรียนเข้าใจหลักการและพร้อมสอบอย่างมั่นใจ
        </p>
      </div>
    </header>

    <!-- ตัวอย่างข้อสอบแนะนำ -->
    <section class="mb-12">
      <a href="/exams/mor1-gifted-science.html" class="block group">
        <div class="bg-gradient-to-r from-primary to-primary-dark rounded-xl p-6 md:p-8 text-white hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-block px-2.5 py-0.5 bg-white/20 rounded-full text-xs font-semibold">ใหม่!</span>
            <span class="inline-block px-2.5 py-0.5 bg-white/20 rounded-full text-xs font-semibold">ฟรี</span>
          </div>
          <h2 class="font-heading text-xl md:text-2xl font-bold mb-2 group-hover:underline">
            ตัวอย่างข้อสอบวิทยาศาสตร์ สอบเข้า ม.1 ห้อง Gifted — พร้อมเฉลยละเอียด
          </h2>
          <p class="text-white/85 mb-3">แนวข้อสอบวิทยาศาสตร์เตรียมสอบเข้า ม.1 ห้อง Gifted โรงเรียนชั้นนำ พร้อมเฉลยและเหตุผลทุกข้อ</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-white/90 group-hover:text-white">
            ทำข้อสอบเลย &rarr;
          </span>
        </div>
      </a>
    </section>

    <!-- วิชาที่สอบ -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-6">วิชาที่สอบเข้า ม.1</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {subjects.map((s) => (
          <div class="bg-white border border-border rounded-xl p-5 hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="font-heading font-semibold text-text mb-1">{s.name}</h3>
            <p class="text-sm text-text-light">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ตัวอย่างข้อสอบฟรี -->
    {freeExams.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-bold text-text mb-6">ตัวอย่างข้อสอบเข้า ม.1 ฟรี</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {freeExams.map((exam) => (
            <ExamCard
              title={exam.data.title}
              description={exam.data.description}
              level={exam.data.level}
              subject={exam.data.subject}
              questionCount={exam.data.questionCount}
              difficulty={exam.data.difficulty}
              isFree={exam.data.isFree}
              href={`/exams/mor1/${exam.id}/`}
            />
          ))}
        </div>
      </section>
    )}

    <!-- คู่มือเตรียมสอบ -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">คู่มือเตรียมสอบเข้า ม.1</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          <li>
            <a href="/guides/how-to-prepare-mor1/" class="text-primary hover:text-primary-dark font-medium transition-colors">
              คู่มือเตรียมสอบเข้า ม.1 โรงเรียนชั้นนำ ฉบับสมบูรณ์ &rarr;
            </a>
          </li>
          <li>
            <a href="/blog/" class="text-primary hover:text-primary-dark font-medium transition-colors">
              บทความเทคนิคการสอบ ม.1 &rarr;
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection title="คำถามที่พบบ่อยเกี่ยวกับสอบเข้า ม.1" items={faqItems} />

    <!-- CTA -->
    <CTABanner
      title="เริ่มเตรียมสอบเข้า ม.1 วันนี้"
      description="ดาวน์โหลดตัวอย่างข้อสอบฟรี ฝึกทำให้คุ้นเคยกับรูปแบบข้อสอบจริง"
      buttonText="ดูตัวอย่างข้อสอบฟรี"
      buttonHref="/exams/"
    />
  </div>
</BaseLayout>
