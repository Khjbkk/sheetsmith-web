---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTABanner from '../../../components/CTABanner.astro';

const subjects = [
  { name: 'คณิตศาสตร์', icon: '🔢', desc: 'พีชคณิต เรขาคณิต และโจทย์ปัญหาประยุกต์ — สาธิตปทุมวันออกข้อที่ต้องวิเคราะห์ ไม่ใช่แค่ท่องสูตร', emphasis: 'high' },
  { name: 'วิทยาศาสตร์', icon: '🔬', desc: 'ฟิสิกส์ เคมี ชีวะระดับ ม.ต้น เน้นเข้าใจหลักการและการประยุกต์', emphasis: 'high' },
  { name: 'ภาษาอังกฤษ', icon: '🔤', desc: 'Grammar tense คำศัพท์ Reading comprehension และ Writing — สาธิตปทุมวันให้น้ำหนักสูง', emphasis: 'high' },
  { name: 'ภาษาไทย', icon: '🇹🇭', desc: 'คำศัพท์ ไวยากรณ์ การอ่านจับใจความ และวรรณคดี', emphasis: 'normal' },
  { name: 'สังคมศึกษา', icon: '🌏', desc: 'ภูมิศาสตร์ ประวัติศาสตร์ หน้าที่พลเมือง ตามหลักสูตรกระทรวง', emphasis: 'normal' },
];

const faqItems = [
  {
    question: 'สาธิตปทุมวันรับเด็กชายและหญิงไหม?',
    answer: 'โรงเรียนสาธิตมหาวิทยาลัยศรีนครินทรวิโรฒ ปทุมวัน (สาธิตปทุมวัน) เป็นโรงเรียน <strong>สหศึกษา</strong> รับทั้งนักเรียนชายและหญิงเข้าเรียนระดับ ม.1 ทุกปี ต่างจากสวนกุหลาบที่เป็นชายล้วน หรือสตรีวิทยาที่เป็นหญิงล้วน สำหรับครอบครัวที่มีลูกสาวต้องการโรงเรียนชั้นนำคุณภาพเทียบเท่าสวนกุหลาบสำหรับเด็กชาย สาธิตปทุมวันถือเป็นทางเลือกอันดับต้นๆ การสอบเข้าเปิดรับเฉลี่ยจำนวนนักเรียนใหม่ประมาณ 200-300 คนต่อรุ่น ซึ่งน้อยกว่าโรงเรียนรัฐบาลขนาดใหญ่ ทำให้การแข่งขันสูงและคะแนนคัดเลือกอยู่ในระดับสูงสุดของกลุ่มสาธิต ผู้ปกครองที่ต้องการให้ลูกได้รับการศึกษาที่เข้มข้นและบรรยากาศโรงเรียนชั้นนำ สาธิตปทุมวันเป็นตัวเลือกที่คุ้มค่า',
  },
  {
    question: 'ข้อสอบเข้า ม.1 สาธิตปทุมวันต่างจากสวนกุหลาบยังไง?',
    answer: 'ข้อสอบสาธิตปทุมวันและสวนกุหลาบมีจุดเหมือนคือทั้งคู่เน้นคณิตและวิทยาศาสตร์ที่ระดับสูง แต่ <strong>สาธิตปทุมวันให้น้ำหนักภาษาอังกฤษมากกว่า</strong> เพราะเป็นโรงเรียนที่มีโครงการ Bilingual และนักเรียนหลายคนต่อยอดเข้ามหาวิทยาลัยต่างประเทศ ส่วน <strong>สวนกุหลาบเน้นคณิต-วิทย์เป็นพิเศษ</strong> เพราะนักเรียนส่วนใหญ่เลือกสายวิทย์-คณิตต่อ ม.4 ในเชิงรูปแบบข้อสอบ สาธิตปทุมวันมักออกข้อที่ต้องวิเคราะห์เชิงสถานการณ์ และมีคำถามภาษาอังกฤษระดับยากกว่าโรงเรียนรัฐบาลปกติ ผู้ปกครองที่เตรียมตัวให้ลูกสอบสาธิตปทุมวันควรเสริมพื้นฐานอังกฤษให้แน่นเป็นพิเศษ ในขณะที่สอบสวนกุหลาบควรเน้นคณิต-วิทย์ขั้นสูง',
  },
  {
    question: 'สาธิตปทุมวันเรียน 2 ภาษาไหม?',
    answer: 'สาธิตปทุมวันมีโครงการพิเศษทั้งหลักสูตรปกติและหลักสูตร English Program (EP) หรือ Bilingual ที่สอนเป็นภาษาอังกฤษหลายวิชา การสอบเข้า ม.1 จะแยกตามโครงการที่สมัคร ผู้สมัครหลักสูตรปกติจะสอบเป็นภาษาไทยเป็นหลัก ส่วนผู้สมัครโครงการอินเตอร์/EP จะมีการสอบเฉพาะที่ใช้ภาษาอังกฤษมากกว่า ทั้งสองโครงการมีคุณภาพการสอนสูง ผู้ปกครองควรเลือกตามความถนัดของลูกและเป้าหมายการศึกษาต่อ ลูกที่มีพื้นภาษาอังกฤษแข็งและตั้งใจเรียนต่อต่างประเทศ EP อาจเหมาะกว่า ลูกที่ต้องการพื้นฐานวิชาการแบบไทยและสอบเข้ามหาวิทยาลัยไทย หลักสูตรปกติของสาธิตปทุมวันก็ยอดเยี่ยมไม่แพ้กัน',
  },
  {
    question: 'ควรเริ่มเตรียมสอบเข้าสาธิตปทุมวันเมื่อไหร่?',
    answer: 'แนะนำให้เริ่มเตรียมตัวอย่างจริงจังตั้งแต่ <strong>ป.5 หรือกลางปี ป.6</strong> ช่วงปลายเทอม ป.5 ถึงต้นเทอม 1 ป.6 ควรปูพื้นฐานคณิตและวิทย์ให้แม่น พร้อมเสริมภาษาอังกฤษด้วยการอ่านหนังสือนิทาน-นวนิยายภาษาอังกฤษระดับ Intermediate และฝึก grammar tense จากหนังสือเรียน Cambridge หรือ Oxford ในช่วงต้นปี ป.6 เริ่มทำข้อสอบจริงจาก SheetSmith และแหล่งอื่นสัปดาห์ละ 1-2 ชุด เน้นทำซ้ำในวิชาที่อ่อน 3 เดือนสุดท้ายซ้อมจับเวลาทำข้อสอบเต็มชุด เพื่อให้คุ้นกับสภาวะสอบจริง การเตรียมตัว 12-18 เดือนคือช่วงเวลาที่เหมาะสม ไม่สั้นจนรีบและไม่ยาวจนเด็กเบื่อ',
  },
  {
    question: 'ถ้าสอบไม่ติดสาธิตปทุมวัน โรงเรียนทางเลือกใกล้เคียงคืออะไร?',
    answer: 'หากสอบไม่ติดสาธิตปทุมวัน ยังมีโรงเรียนสหศึกษาคุณภาพดีที่ควรพิจารณา เช่น <strong>สาธิตประสานมิตร</strong> สาธิตเกษตร (ระดับมัธยม) สาธิตจุฬาฝ่ายมัธยม โรงเรียนเตรียมอุดมศึกษาน้อมเกล้า สามเสนวิทยาลัย บดินทรเดชา (สิงห์ สิงหเสนี) เป็นโรงเรียนรัฐบาลที่มีคุณภาพการสอนสูงและรับนักเรียนเป็นจำนวนมาก ส่วนโรงเรียนเอกชนชั้นนำ เช่น มาแตร์เดอี เซนต์โยเซฟคอนแวนต์ และเรยีนา เป็นทางเลือกสำหรับลูกสาว สำหรับลูกชายมีอัสสัมชัญ กรุงเทพคริสเตียน เซนต์คาเบรียล หลายครอบครัวเลือกสมัครหลายโรงเรียนเพื่อเพิ่มโอกาส คุณภาพการศึกษาในระยะยาวขึ้นอยู่กับเด็กและการสนับสนุนของครอบครัวมากกว่าชื่อโรงเรียน',
  },
];

const relatedSamples = [
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ เข้า ม.1 พร้อมเฉลย', href: '/exams/mor1/mor1-math-sample/' },
  { title: 'ตัวอย่างข้อสอบคณิตศาสตร์ ม.1 ระดับสูง', href: '/exams/mor1/mor1-math-advanced-sample/' },
  { title: 'ตัวอย่างข้อสอบวิทยาศาสตร์ เข้า ม.1', href: '/exams/mor1/mor1-science-sample/' },
  { title: 'ตัวอย่างข้อสอบภาษาอังกฤษ เข้า ม.1', href: '/exams/mor1/mor1-english-sample/' },
];

const relatedReads = [
  { title: 'คู่มือเตรียมสอบเข้า ม.1 โรงเรียนชั้นนำ ฉบับสมบูรณ์', href: '/guides/how-to-prepare-mor1/' },
  { title: 'เทคนิคเตรียมสอบคณิต ม.1', href: '/blog/math-tips-mor1/' },
  { title: 'ข้อสอบคณิต ม.1 ย้อนหลัง ปี 2568', href: '/blog/mor1-math-past-exams-2568/' },
  { title: 'ข้อสอบวิทยาศาสตร์ ม.1 — แนวข้อสอบและเทคนิค', href: '/blog/mor1-science-past-exams/' },
  { title: 'โรงเรียนชั้นนำสอบเข้า ม.1 ในกรุงเทพ', href: '/blog/top-schools-mor1-bangkok/' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ข้อสอบเข้า ม.1 สาธิตปทุมวัน — แนวข้อสอบฟรี พร้อมเฉลยละเอียด',
  description: 'รวมแนวข้อสอบเข้า ม.1 สาธิตปทุมวัน คณิต วิทย์ อังกฤษระดับสูง พร้อมเฉลยแบบติวเตอร์ ดาวน์โหลดตัวอย่างฟรี',
  url: 'https://sheetsmith.org/exams/mor1/satit-patumwan/',
  inLanguage: 'th-TH',
  isPartOf: { '@type': 'WebSite', name: 'SheetSmith', url: 'https://sheetsmith.org' },
  about: {
    '@type': 'EducationalOrganization',
    name: 'โรงเรียนสาธิตมหาวิทยาลัยศรีนครินทรวิโรฒ ปทุมวัน',
    alternateName: 'สาธิตปทุมวัน',
  },
};
---

<BaseLayout
  title="ข้อสอบเข้า ม.1 สาธิตปทุมวัน ฟรี พร้อมเฉลยละเอียด 2569"
  description="รวมแนวข้อสอบเข้า ม.1 สาธิตปทุมวัน (สาธิต มศว ปทุมวัน) ฟรี คณิต วิทย์ อังกฤษระดับสูง พร้อมเฉลยแบบติวเตอร์ step-by-step"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: 'ข้อสอบ', href: '/exams/' },
      { label: 'สอบเข้า ม.1', href: '/exams/mor1/' },
      { label: 'สาธิตปทุมวัน' },
    ]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
        ข้อสอบเข้า ม.1 สาธิตปทุมวัน — ฟรี พร้อมเฉลยละเอียดจากสนามจริง
      </h1>
      <div class="prose max-w-none text-text-light">
        <p>
          โรงเรียนสาธิตมหาวิทยาลัยศรีนครินทรวิโรฒ ปทุมวัน (สาธิตปทุมวัน) เป็นโรงเรียนสหศึกษาชั้นนำของประเทศ มีจุดเด่นด้าน <strong>คณิต-วิทย์-ภาษาอังกฤษ</strong> และมีโครงการ Bilingual ที่เด่นในหมู่โรงเรียนสาธิต ข้อสอบเข้า ม.1 มีระดับยากใกล้เคียงสวนกุหลาบ แต่ภาษาอังกฤษเข้มข้นกว่า
        </p>
        <p>
          หน้านี้รวมแนวข้อสอบเข้า ม.1 สาธิตปทุมวัน พร้อมเฉลยแบบติวเตอร์ทุกข้อ ทั้งตัวอย่างฟรีและชุดเต็ม ครอบคลุมวิชาหลักที่ออกสอบจริง
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ภาพรวมข้อสอบเข้า ม.1 สาธิตปทุมวัน</h2>
      <div class="prose max-w-none text-text-light mb-6">
        <p>
          ข้อสอบเข้า ม.1 สาธิตปทุมวันให้น้ำหนัก <strong>คณิตศาสตร์ วิทยาศาสตร์ และภาษาอังกฤษ</strong> มากกว่าวิชาอื่น เพราะตรงกับเป้าหมายของโรงเรียนที่ผลิตนักเรียนสู่สายวิทย์-คณิตและการศึกษาต่อต่างประเทศ
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {subjects.map((s) => (
          <div class={`bg-white border rounded-xl p-5 ${s.emphasis === 'high' ? 'border-primary/40 ring-1 ring-primary/10' : 'border-border'}`}>
            <div class="flex items-center gap-3 mb-2">
              <div class="text-3xl">{s.icon}</div>
              <h3 class="font-heading font-semibold text-text">{s.name}</h3>
              {s.emphasis === 'high' && (
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">น้ำหนักสูง</span>
              )}
            </div>
            <p class="text-sm text-text-light leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ตัวอย่างคำถามแนวข้อสอบ + เฉลยแบบติวเตอร์</h2>
      <p class="text-text-light mb-6">
        ตัวอย่างด้านล่างเป็นโจทย์วิทยาศาสตร์แนวที่พบบ่อยในข้อสอบเข้า ม.1 สาธิตปทุมวัน (ไม่ใช่ข้อสอบจริง — เป็นตัวอย่างเพื่อให้เห็นรูปแบบและวิธีคิด)
      </p>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-4">
        <p class="font-semibold text-text mb-2">โจทย์ (วิทยาศาสตร์ — ระบบนิเวศ)</p>
        <p class="text-text-light leading-relaxed">
          สิ่งมีชีวิตชนิดใดต่อไปนี้เป็น "ผู้ผลิต" ในระบบนิเวศ?<br />
          ก. กระต่าย ข. ต้นไม้ ค. สิงโต ง. เห็ด
        </p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <p class="font-semibold text-text mb-3">เฉลยแบบติวเตอร์</p>
        <ol class="list-decimal list-inside space-y-2 text-text-light leading-relaxed">
          <li><strong>วิธีอ่านโจทย์</strong> — โจทย์ถามว่าสิ่งใดเป็น "ผู้ผลิต" (Producer) ในระบบนิเวศ ต้องรู้นิยามของผู้ผลิตในห่วงโซ่อาหารก่อน</li>
          <li><strong>นิยามที่ต้องจำ</strong> — ผู้ผลิตคือสิ่งมีชีวิตที่สามารถสร้างอาหารเองได้ ส่วนใหญ่คือพืชที่ใช้กระบวนการสังเคราะห์แสง</li>
          <li><strong>วิเคราะห์ตัวเลือก</strong> — กระต่ายและสิงโตเป็นสัตว์ที่ต้องกินอาหาร = ผู้บริโภค เห็ดเป็นเชื้อราที่ย่อยสลายสารอินทรีย์ = ผู้ย่อยสลาย ต้นไม้สามารถสร้างอาหารผ่านสังเคราะห์แสง = ผู้ผลิต</li>
          <li><strong>คำตอบ</strong> — ข้อ ข. ต้นไม้</li>
          <li><strong>เทคนิคหลีกเลี่ยงข้อผิดพลาด</strong> — เด็กบางคนอาจเลือกเห็ดเพราะคิดว่าเห็ดเป็นพืช แต่จริงๆ เห็ดคือเชื้อราในอาณาจักร Fungi ซึ่งไม่สามารถสังเคราะห์แสงได้ การจำแนกกลุ่มสิ่งมีชีวิตในระบบนิเวศ (ผู้ผลิต ผู้บริโภค ผู้ย่อยสลาย) เป็นพื้นฐานสำคัญที่จะถูกถามต่อเนื่องในระดับ ม.1-ม.3</li>
        </ol>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">ดาวน์โหลดตัวอย่างข้อสอบเข้า ม.1 สาธิตปทุมวัน ฟรี</h2>
      <div class="bg-white border border-border rounded-xl p-6">
        <ul class="space-y-3">
          {relatedSamples.map((s) => (
            <li>
              <a href={s.href} class="text-primary hover:text-primary-dark font-medium transition-colors">
                {s.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-light mt-4">
