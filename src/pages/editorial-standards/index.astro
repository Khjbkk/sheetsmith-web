---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const lastReviewed = new Date('2026-06-28').toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });

const standardsSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://tidfun.org/editorial-standards/',
  name: 'มาตรฐานบรรณาธิการ — ติดฝัน',
  description: 'นโยบายการรวบรวมข้อมูล การตรวจสอบ การเรียบเรียง การอัปเดต และการแก้ไขข้อมูลของติดฝัน — directory สถาบันกวดวิชาและติวเตอร์ในประเทศไทย',
  about: { '@id': 'https://tidfun.org/#org' },
  publisher: { '@id': 'https://tidfun.org/#org' },
  mainEntity: { '@id': 'https://tidfun.org/#editorial-team' },
  dateModified: '2026-06-28',
};
---

<BaseLayout
  title="มาตรฐานบรรณาธิการ — ติดฝัน"
  description="วิธีที่ทีมงานติดฝันรวบรวมข้อมูลสถาบันกวดวิชา ตรวจสอบความถูกต้อง เรียบเรียงคำอธิบาย กำหนดราคาประมาณการ อัปเดตข้อมูล และแก้ไขเมื่อพบข้อมูลผิดพลาด"
>
  <script type="application/ld+json" set:html={JSON.stringify(standardsSchema)} />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <Breadcrumb items={[{ label: 'มาตรฐานบรรณาธิการ' }]} />

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">มาตรฐานบรรณาธิการ</h1>
      <p class="text-gray-600">ติดฝันสร้างขึ้นเพื่อช่วยให้ผู้ปกครองและนักเรียนตัดสินใจเลือกสถาบันกวดวิชาได้อย่างมีข้อมูล หน้านี้อธิบายขั้นตอนการทำงานของทีมและกติกาที่ทีมยึดถือเพื่อให้ข้อมูลที่ปรากฏบนเว็บไซต์โปร่งใสและใช้ตัดสินใจได้จริง</p>
      <p class="text-xs text-gray-500 mt-3">ทบทวนล่าสุด: {lastReviewed}</p>
    </header>

    <section class="prose prose-indigo max-w-none">
      <h2>1. แหล่งข้อมูล</h2>
      <p>ข้อมูลสถาบันบนติดฝันรวบรวมจากแหล่งสาธารณะหลายแหล่งร่วมกัน เพื่อให้แต่ละ listing มีหลายมุมมองไม่พึ่งแหล่งเดียว แหล่งข้อมูลหลักที่ทีมใช้คือ:</p>
      <ul>
        <li><strong>Google Maps</strong> — ใช้ดึงชื่อสถาบัน ที่อยู่ พิกัด เบอร์ติดต่อ เว็บไซต์ คะแนนรีวิว และจำนวนรีวิว</li>
        <li><strong>Facebook Pages สาธารณะ</strong> — ใช้เสริมข้อมูลกิจกรรม คอร์ส และช่องทางติดต่ออื่นเมื่อมีหน้าเพจที่เปิดสาธารณะ</li>
        <li><strong>ฐานข้อมูลสถานศึกษากระทรวงศึกษาธิการ (เฉพาะหน้าที่อ้างอิงโรงเรียนเป้าหมาย)</strong> — ใช้ยืนยันการมีอยู่จริงของโรงเรียนเป้าหมายที่ปรากฏในหน้า /for-school/</li>
        <li><strong>ทีมงานติดฝัน</strong> — ทำหน้าที่ตรวจสอบและเรียบเรียงข้อมูลทั้งหมดก่อนเผยแพร่</li>
      </ul>

      <h2>2. ขั้นตอนการทำงาน 4 ขั้น</h2>
      <ol>
        <li><strong>รวบรวม (Collect)</strong> — ดึงข้อมูลสถาบันจากแหล่งสาธารณะตามรายชื่อจังหวัด/ระดับ/โรงเรียน</li>
        <li><strong>ตรวจสอบ (Verify)</strong> — ทีมตรวจชื่อ ที่อยู่ พิกัด ความถูกต้องของจังหวัด/อำเภอ และตัด listing ที่ไม่ใช่สถาบันกวดวิชา (เช่น ร้านอาหาร โรงเรียน หรือธุรกิจที่ไม่เกี่ยวข้อง) ออกก่อนเผยแพร่</li>
        <li><strong>เรียบเรียง (Enrich)</strong> — เขียนคำอธิบายภาษาไทย คำถามที่พบบ่อย และข้อมูลสรุปแบบสั้นจากข้อมูลที่ตรวจสอบแล้ว ภายใต้กติกาที่กำหนดในข้อ 3</li>
        <li><strong>เผยแพร่ (Publish)</strong> — เผยแพร่ listing เข้าระบบ พร้อมระบุวันที่อัปเดตและแหล่งข้อมูลในส่วนท้ายของหน้า</li>
      </ol>

      <h2>3. กติกาเนื้อหา</h2>
      <ul>
        <li><strong>ไม่กล่าวอ้างเปอร์เซ็นต์การสอบติดที่ยังไม่ได้รับการยืนยัน</strong> — ไม่มีหน้าใดในติดฝันที่บอกว่าสถาบันมีอัตราสอบติด X% เว้นแต่จะได้รับการยืนยันจากสถาบันโดยตรงและทีมตรวจสอบแล้ว</li>
        <li><strong>ไม่ระบุชื่อ "ครูประจำตัว" ที่ทีมยังไม่ได้ยืนยัน</strong> — เพื่อป้องกันการให้ข้อมูลครูที่ไม่ได้สอนจริงในสถาบันแล้ว</li>
        <li><strong>ราคาเป็นการประมาณการ</strong> — ราคาที่แสดงบนหน้า listing เป็นการประมาณการจากช่วงราคาทั่วไปของสถาบันในระดับและพื้นที่เดียวกัน ไม่ใช่ราคาจริงที่สถาบันประกาศ ผู้ใช้ควรติดต่อสถาบันเพื่อยืนยันราคาก่อนตัดสินใจ</li>
        <li><strong>ไม่จัดอันดับเพื่อโฆษณา</strong> — ลำดับการแสดงผลใน /best-of/ และ /best-school-tutor/ พิจารณาจาก signals สาธารณะ เช่น คะแนน Google + จำนวนรีวิว + ความเหมาะสมกับโรงเรียนเป้าหมาย ไม่มีการรับเงินเพื่อเลื่อนอันดับ</li>
      </ul>

      <h2>4. การอัปเดตและความสด</h2>
      <p>ทุก listing จะแสดงวันที่อัปเดตล่าสุดในส่วนท้ายของหน้า ทีมตั้งเป้าทบทวนข้อมูลสถาบันอย่างน้อยปีละครั้ง หรือเมื่อมีผู้แจ้งข้อมูลเปลี่ยนแปลงผ่านหน้า /claim/ หรืออีเมล <code>info@tidfun.com</code></p>

      <h2>5. การแก้ไขข้อมูลผิดพลาด</h2>
      <p>หากพบข้อมูลผิดพลาดในหน้าใดของติดฝัน โปรดส่งข้อความถึงทีมงานที่ <a href="/contact/" class="text-indigo-600 hover:underline">/contact/</a> หรืออีเมล <code>info@tidfun.com</code> ทีมจะตรวจสอบและแก้ไขภายใน 7 วันทำการ พร้อมอัปเดตวันที่ทบทวนล่าสุดของหน้านั้น สำหรับเจ้าของสถาบันที่ต้องการเคลม listing ของตัวเอง สามารถใช้แบบฟอร์มที่ <a href="/claim/" class="text-indigo-600 hover:underline">/claim/</a></p>

      <h2>6. การเปิดเผยความสัมพันธ์ทางธุรกิจ</h2>
      <p>ติดฝันไม่เป็นตัวกลางในการสมัครเรียน ไม่รับค่าคอมมิชชั่นจากการสมัครเรียน และไม่ได้เป็นพาร์ทเนอร์โฆษณาประจำกับสถาบันใดสถาบันหนึ่ง รายได้ของเว็บไซต์อาจมาจากการที่สถาบันสมัครเป็นสมาชิกแบบเสียค่าบริการเพื่อปรับปรุงและจัดการข้อมูลของตัวเองในอนาคต ซึ่งจะไม่กระทบลำดับการแสดงผลในหน้าจัดอันดับ</p>

      <h2>7. ผู้รับผิดชอบเนื้อหา</h2>
      <p>เนื้อหาทั้งหมดบนติดฝันอยู่ภายใต้การดูแลของ <strong>ทีมงานติดฝัน</strong> ภายใต้บริษัท <strong>ซิโอร่า จำกัด</strong> หากต้องการติดต่อทีมงานโดยตรง ใช้ช่องทาง <a href="/contact/" class="text-indigo-600 hover:underline">/contact/</a></p>
    </section>

    <div class="mt-12 pt-6 border-t border-gray-200 text-sm text-gray-500">
      <p>หากต้องการอ่านนโยบายอื่นที่เกี่ยวข้อง: <a href="/privacy/" class="text-indigo-600 hover:underline">ความเป็นส่วนตัว</a> · <a href="/terms/" class="text-indigo-600 hover:underline">ข้อตกลงการใช้งาน</a></p>
    </div>
  </div>
</BaseLayout>
