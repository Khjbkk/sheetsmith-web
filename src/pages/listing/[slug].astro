---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map((l) => ({
    params: { slug: l.id },
    props: { listing: l },
  }));
}

const { listing } = Astro.props;
const d = listing.data;
const { Content } = await render(listing);

const categoryLabel: Record<string, string> = {
  por1: 'เตรียมสอบเข้า ป.1',
  mor1: 'เตรียมสอบเข้า ม.1',
  mor4: 'เตรียมสอบเข้า ม.4',
  uni: 'เตรียมสอบเข้ามหาวิทยาลัย',
  all: 'ทุกระดับ',
};

const tierLabel = { budget: 'งบประหยัด', mid: 'งบกลาง', premium: 'พรีเมียม' }[d.pricing_tier];
const formatLabel: Record<string, string> = {
  in_person: 'พบหน้า', online: 'ออนไลน์', hybrid: 'Hybrid',
};

// LocalBusiness schema
const listingSchema: any = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://${Astro.site?.host}/listing/${listing.id}/`,
  name: d.name_th,
  description: d.description_th,
  address: {
    '@type': 'PostalAddress',
    streetAddress: d.address_th,
    addressLocality: d.city,
    addressCountry: 'TH',
  },
  ...(d.lat && d.lng ? { geo: { '@type': 'GeoCoordinates', latitude: d.lat, longitude: d.lng } } : {}),
  ...(d.phone.length > 0 ? { telephone: d.phone[0] } : {}),
  ...(d.website ? { url: d.website } : {}),
  ...(d.email ? { email: d.email } : {}),
  ...(d.founded_year ? { foundingDate: `${d.founded_year}` } : {}),
  priceRange: { budget: '฿', mid: '฿฿', premium: '฿฿฿' }[d.pricing_tier],
  ...(d.google_rating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: d.google_rating,
      reviewCount: d.google_review_count || 0,
    },
  } : {}),
};

// Speakable schema (AEO)
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'SpeakableSpecification',
  cssSelector: ['.speakable-1', '.speakable-2', '.speakable-3'],
};

// FAQPage
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faq.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout
  title={`${d.name_th} — รีวิว ราคา คอร์ส | ติดฝัน`}
  description={d.description_th.slice(0, 155)}
>
  <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: categoryLabel[d.categories[0]] || 'ข้อมูลทั่วไป', href: `/category/${d.categories[0]}/` },
      { label: d.name_th },
    ]} />

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">{d.name_th}</h1>
          {d.name_en && <p class="text-gray-500">{d.name_en}</p>}
          <p class="text-sm text-gray-600 mt-1">{d.district ? `${d.district} · ` : ''}{d.city}</p>
        </div>
        <div class="flex flex-col items-end gap-2">
          {d.featured && <span class="text-xs px-2.5 py-1 bg-amber-100 text-amber-800 rounded-full font-semibold">★ Featured</span>}
          {d.claimed ? (
            <span class="text-xs px-2.5 py-1 bg-green-100 text-green-700 rounded-full font-medium">✓ ยืนยันแล้ว</span>
          ) : (
            <a href="/claim/" class="text-xs px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full hover:bg-indigo-100 hover:text-indigo-700 transition-colors">เป็นเจ้าของ? เคลมสถาบันนี้</a>
          )}
        </div>
      </div>
      {d.google_rating && (
        <div class="flex items-center gap-2 text-sm">
          <span class="text-amber-500 text-lg">★★★★★</span>
          <span class="font-semibold text-gray-900">{d.google_rating.toFixed(1)}</span>
          {d.google_review_count && <span class="text-gray-500">({d.google_review_count} รีวิวจาก Google)</span>}
        </div>
      )}
    </header>

    <!-- Quick Facts -->
    <section class="mb-8 grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ราคา</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.price_range}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ห้องเรียน</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.class_size}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">รูปแบบ</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.format.map(f => formatLabel[f] || f).join(', ')}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ช่วงอายุ</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.age_range}</p>
      </div>
    </section>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-3">เกี่ยวกับ {d.name_th}</h2>
      <p class="text-gray-700 leading-relaxed">{d.description_th}</p>
    </section>

    <!-- Speakable AEO paragraphs -->
    <section class="mb-8 bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-6">
      <h2 class="text-lg font-bold text-amber-900 mb-3">สรุปสั้นๆ</h2>
      <div class="space-y-3 text-gray-800">
        <p class="speakable-1 leading-relaxed">{d.speakable_th[0]}</p>
        <p class="speakable-2 leading-relaxed">{d.speakable_th[1]}</p>
        <p class="speakable-3 leading-relaxed">{d.speakable_th[2]}</p>
      </div>
    </section>

    <!-- Coverage -->
    <section class="mb-8 grid md:grid-cols-2 gap-6">
      <div>
        <h3 class="font-bold text-gray-900 mb-3">เตรียมสอบสำหรับ</h3>
        <div class="flex flex-wrap gap-2">
          {d.categories.map(c => (
            <a href={`/category/${c}/`} class="text-sm px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full hover:bg-indigo-200 transition-colors">{categoryLabel[c]}</a>
          ))}
        </div>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-3">วิชาที่สอน</h3>
        <div class="flex flex-wrap gap-2">
          {d.subjects.map(s => (
            <a href={`/subject/${s}/`} class="text-sm px-3 py-1 bg-gray-100 text-gray-700 rounded-full hover:bg-gray-200 transition-colors">{s}</a>
          ))}
        </div>
      </div>
    </section>

    {d.target_schools.length > 0 && (
      <section class="mb-8">
        <h3 class="font-bold text-gray-900 mb-3">เตรียมสอบเข้าโรงเรียน</h3>
        <div class="flex flex-wrap gap-2">
          {d.target_schools.map(s => (
            <a href={`/for-school/${s}/`} class="text-sm px-3 py-1 bg-purple-100 text-purple-700 rounded-full hover:bg-purple-200 transition-colors">{s}</a>
          ))}
        </div>
      </section>
    )}

    <!-- Contact -->
    <section class="mb-8 bg-gray-50 border border-gray-200 rounded-xl p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ติดต่อ {d.name_th}</h2>
      <div class="space-y-2 text-sm">
        {d.address_th && <p><strong class="text-gray-700">ที่อยู่:</strong> {d.address_th}</p>}
        {d.phone.length > 0 && <p><strong class="text-gray-700">โทร:</strong> {d.phone.join(', ')}</p>}
        {d.line_id && <p><strong class="text-gray-700">LINE:</strong> {d.line_id}</p>}
        {d.facebook_url && <p><strong class="text-gray-700">Facebook:</strong> <a href={d.facebook_url} class="text-indigo-600 hover:underline" rel="noopener">{d.facebook_url}</a></p>}
        {d.website && <p><strong class="text-gray-700">เว็บไซต์:</strong> <a href={d.website} class="text-indigo-600 hover:underline" rel="noopener">{d.website}</a></p>}
        {d.email && <p><strong class="text-gray-700">Email:</strong> {d.email}</p>}
      </div>
      <p class="text-xs text-gray-500 mt-4">ติดต่อสถาบันโดยตรงผ่านช่องทางด้านบน ติดฝันไม่เป็นตัวกลางในการสมัครเรียนหรือชำระเงิน</p>
    </section>

    <!-- Markdown body content -->
    <section class="prose max-w-none mb-8">
      <Content />
    </section>

    <FAQSection items={d.faq} title={`คำถามที่พบบ่อยเกี่ยวกับ ${d.name_th}`} />

    <!-- Anti-thin / Trust footer -->
    <section class="my-8 text-xs text-gray-500 border-t border-gray-200 pt-4">
      <p>ข้อมูลอัปเดตล่าสุด: {d.data_freshness_date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <p>แหล่งข้อมูล: {d.sources.join(', ')}</p>
      {!d.claimed && (
        <p class="mt-2">หากเป็นเจ้าของสถาบันนี้ <a href="/claim/" class="text-indigo-600 hover:underline">เคลมเพื่อปรับปรุงข้อมูล</a></p>
      )}
    </section>
  </div>
</BaseLayout>
