---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': 'https://tidfun.org/contact/',
  url: 'https://tidfun.org/contact/',
  name: 'ติดต่อ ติดฝัน',
  description: 'ติดต่อทีมงานติดฝัน (TidFun) ผ่าน Email หรือ LINE สอบถามข้อมูล แนะนำสถาบัน เพิ่มสถาบัน หรือร่วมงาน — ตอบกลับ Email ภายใน 24 ชม.',
  inLanguage: 'th',
  isPartOf: { '@id': 'https://tidfun.org/#org' },
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://tidfun.org/#org',
    contactPoint: [
      {
        '@type': 'ContactPoint',
        email: 'info@tidfun.com',
        contactType: 'customer service',
        availableLanguage: ['Thai', 'English'],
        hoursAvailable: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '09:00', closes: '18:00' },
        responseTime: 'P1D',
      },
      {
        '@type': 'ContactPoint',
        contactType: 'sales',
        email: 'info@tidfun.com',
        availableLanguage: ['Thai'],
        productSupported: ['Featured listing', 'Newsletter sponsorship'],
      },
    ],
  },
};
---

<BaseLayout
  title="ติดต่อ ติดฝัน"
  description="ติดต่อทีมงาน ติดฝัน (TidFun) สอบถาม แนะนำสถาบัน หรือร่วมงานกับเรา ผ่าน Email หรือ LINE"
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ label: 'ติดต่อเรา' }]} />

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">ติดต่อ ติดฝัน</h1>

    <p class="text-gray-700 mb-8">
      มีคำถาม ต้องการแนะนำสถาบัน เป็นเจ้าของสถาบันที่อยากเพิ่มเข้า directory หรืออยากร่วมงานกับเรา ติดต่อได้ตามช่องทางด้านล่าง
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-green-700" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <h2 class="font-bold text-gray-900 mb-2">LINE</h2>
        <p class="text-indigo-600 font-semibold text-lg">@tidfun</p>
        <p class="text-sm text-gray-500 mt-2">ตอบกลับเร็วที่สุด</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-indigo-700" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <h2 class="font-bold text-gray-900 mb-2">Email</h2>
        <p class="text-indigo-600 font-semibold text-lg">info@tidfun.com</p>
        <p class="text-sm text-gray-500 mt-2">ตอบกลับภายใน 24 ชม.</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl">➕</span>
        </div>
        <h2 class="font-bold text-gray-900 mb-2">เพิ่มสถาบัน</h2>
        <a href="/claim/" class="text-indigo-600 font-semibold hover:underline">ฟอร์มเคลม &rarr;</a>
        <p class="text-sm text-gray-500 mt-2">ฟรี ใช้เวลา 5 นาที</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl">📰</span>
        </div>
        <h2 class="font-bold text-gray-900 mb-2">โฆษณากับเรา</h2>
        <p class="text-indigo-600 font-semibold">info@tidfun.com</p>
        <p class="text-sm text-gray-500 mt-2">Featured listing / Newsletter</p>
      </div>
    </div>
  </div>
</BaseLayout>
