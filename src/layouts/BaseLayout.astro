---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
}

const props = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'SheetSmith',
  url: Astro.site?.toString(),
  description: 'ตัวอย่างข้อสอบเตรียมสอบเข้า ป.1 ม.1 ม.4 โรงเรียนสาธิตและโรงเรียนชั้นนำ',
  areaServed: { '@type': 'Country', name: 'Thailand' },
  sameAs: [
    'https://www.facebook.com/sheetsmith',
    'https://line.me/ti/p/@sheetsmith',
  ],
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <SEOHead {...props} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <!-- Google Analytics (GA4) - G-W0ND9TWZX6 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W0ND9TWZX6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W0ND9TWZX6');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
