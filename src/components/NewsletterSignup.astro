---
interface Props {
  variant?: 'inline' | 'footer';
}
const { variant = 'inline' } = Astro.props;
---

{variant === 'inline' ? (
  <section class="my-12 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-8 md:p-10 text-white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-2">รับข่าวสารติดฝัน Weekly</h2>
      <p class="text-white/85 mb-6">รวมสถาบันใหม่ บทความเตรียมสอบ และเคล็ดลับ ส่งทุกสัปดาห์ — ฟรี ไม่มี spam</p>
      <form action="https://formspree.io/f/your-form-id" method="post" class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto">
        <input type="email" name="email" placeholder="email@example.com" required class="flex-1 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-white" />
        <button type="submit" class="px-6 py-3 bg-amber-400 text-amber-900 font-bold rounded-lg hover:bg-amber-300 transition-colors">สมัครฟรี</button>
      </form>
      <p class="text-xs text-white/70 mt-3">เราเคารพข้อมูลส่วนตัวคุณตาม PDPA — ยกเลิกได้ทุกเมื่อ</p>
    </div>
  </section>
) : (
  <div class="bg-white/5 rounded-lg p-4 mb-6">
    <h4 class="font-semibold text-white mb-2 text-sm">📬 ติดฝัน Weekly</h4>
    <p class="text-xs text-white/60 mb-3">รับข่าวสาร สถาบันใหม่ และเคล็ดลับเตรียมสอบ</p>
    <form action="https://formspree.io/f/your-form-id" method="post" class="flex flex-col gap-2">
      <input type="email" name="email" placeholder="email" required class="w-full px-3 py-2 bg-white/10 border border-white/20 rounded text-white placeholder-white/40 text-sm focus:outline-none focus:ring-1 focus:ring-white/40" />
      <button type="submit" class="px-3 py-2 bg-amber-400 text-amber-900 font-semibold rounded text-sm hover:bg-amber-300 transition-colors">สมัครฟรี</button>
    </form>
  </div>
)}
