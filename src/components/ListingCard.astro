---
interface Props {
  slug: string;
  name_th: string;
  city: string;
  district?: string;
  categories: string[];
  subjects: string[];
  pricing_tier: 'budget' | 'mid' | 'premium';
  format: string[];
  google_rating?: number;
  google_review_count?: number;
  description_excerpt: string;
  featured?: boolean;
  claimed?: boolean;
}

const props = Astro.props;
const tierBadge = {
  budget: { label: 'งบประหยัด', color: 'bg-green-100 text-green-700' },
  mid: { label: 'งบกลาง', color: 'bg-blue-100 text-blue-700' },
  premium: { label: 'พรีเมียม', color: 'bg-purple-100 text-purple-700' },
}[props.pricing_tier];

const categoryLabel: Record<string, string> = {
  por1: 'ป.1', mor1: 'ม.1', mor4: 'ม.4', uni: 'มหาลัย', all: 'ทุกระดับ',
};
const formatLabel: Record<string, string> = {
  in_person: 'พบหน้า', online: 'ออนไลน์', hybrid: 'Hybrid',
};
---

<a href={`/listing/${props.slug}/`} class="block bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md hover:border-indigo-300 transition-all group">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-1 truncate">{props.name_th}</h3>
      <p class="text-xs text-gray-500">{props.district ? `${props.district} · ${props.city}` : props.city}</p>
    </div>
    {props.featured && <span class="text-xs px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full font-medium shrink-0">★ Featured</span>}
    {!props.claimed && <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full shrink-0">ยังไม่ได้เคลม</span>}
  </div>

  <p class="text-sm text-gray-600 leading-relaxed mb-3 line-clamp-2">{props.description_excerpt}</p>

  <div class="flex flex-wrap gap-1.5 mb-3">
    {props.categories.slice(0, 3).map((c) => (
      <span class="text-xs px-2 py-0.5 bg-indigo-50 text-indigo-700 rounded-full">{categoryLabel[c] || c}</span>
    ))}
    {props.subjects.slice(0, 3).map((s) => (
      <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-700 rounded-full">{s}</span>
    ))}
  </div>

  <div class="flex items-center justify-between text-xs">
    <div class="flex items-center gap-2">
      <span class={`px-2 py-0.5 rounded-full font-medium ${tierBadge.color}`}>{tierBadge.label}</span>
      <span class="text-gray-500">{props.format.map(f => formatLabel[f] || f).join(' · ')}</span>
    </div>
    {props.google_rating && (
      <div class="flex items-center gap-1 text-gray-700">
        <span class="text-amber-500">★</span>
        <span class="font-medium">{props.google_rating.toFixed(1)}</span>
        {props.google_review_count && <span class="text-gray-400">({props.google_review_count})</span>}
      </div>
    )}
  </div>
</a>
