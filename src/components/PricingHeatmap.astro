---
// Pricing visualization: rows = category, cols = pricing tier
// Cell value = count of listings in that combination
import { getCollection } from 'astro:content';
const listings = await getCollection('listings');

const cats = ['por1', 'mor1', 'mor4', 'uni'] as const;
const tiers = ['budget', 'mid', 'premium'] as const;

const matrix = cats.map(c => tiers.map(t =>
  listings.filter(l => l.data.categories.includes(c) && l.data.pricing_tier === t).length
));

const max = Math.max(...matrix.flat());

const catLabel: Record<string, string> = { por1: 'ป.1', mor1: 'ม.1', mor4: 'ม.4', uni: 'มหาลัย' };
const tierLabel = { budget: 'งบประหยัด', mid: 'งบกลาง', premium: 'พรีเมียม' };
const tierPriceHint = { budget: '< ฿2,000', mid: '฿2,000-5,000', premium: '> ฿5,000' };
---

<section class="my-12">
  <h2 class="text-2xl font-bold text-gray-900 mb-2">แผนที่ราคาติว — ดูว่ามีของในงบไหน</h2>
  <p class="text-gray-600 mb-6">จำนวนสถาบันในแต่ละช่วงราคา × ระดับชั้น สีเข้ม = มีของให้เลือกมาก สีอ่อน = มีน้อย</p>

  <div class="bg-white border border-gray-200 rounded-xl p-6 overflow-x-auto">
    <div class="inline-block min-w-full">
      <div class="grid gap-2" style={`grid-template-columns: 100px repeat(${tiers.length}, 1fr); min-width: 480px;`}>
        <div></div>
        {tiers.map(t => (
          <div class="text-center">
            <p class="text-xs font-semibold text-gray-700">{tierLabel[t]}</p>
            <p class="text-xs text-gray-500">{tierPriceHint[t]}/เดือน</p>
          </div>
        ))}

        {cats.map((c, ci) => (
          <>
            <div class="flex items-center justify-end pr-2">
              <p class="text-sm font-semibold text-gray-700">{catLabel[c]}</p>
            </div>
            {tiers.map((t, ti) => {
              const count = matrix[ci][ti];
              const intensity = max > 0 ? count / max : 0;
              const bgColor = count === 0
                ? 'bg-gray-50'
                : intensity < 0.34
                ? 'bg-indigo-100'
                : intensity < 0.67
                ? 'bg-indigo-300'
                : 'bg-indigo-500';
              const textColor = intensity >= 0.67 ? 'text-white' : 'text-gray-900';
              return (
                <a href={`/search?cat=${c}&tier=${t}`} class={`block rounded-lg p-4 text-center hover:ring-2 hover:ring-indigo-400 transition-all ${bgColor}`}>
                  <p class={`text-2xl font-bold ${textColor}`}>{count}</p>
                  <p class={`text-xs ${textColor} opacity-80`}>สถาบัน</p>
                </a>
              );
            })}
          </>
        ))}
      </div>
    </div>
    <p class="text-xs text-gray-500 mt-4">คลิกที่ช่องเพื่อดูสถาบันในกลุ่มนั้น</p>
  </div>
</section>
