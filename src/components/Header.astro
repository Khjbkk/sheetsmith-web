---
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <div class="w-9 h-9 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg flex items-center justify-center text-white font-bold text-lg">ติ</div>
      <span class="font-bold text-xl text-gray-900 font-heading">ติดฝัน</span>
      <span class="hidden sm:inline text-xs text-gray-500">Tutor Directory</span>
    </a>

    <form action="/search" method="get" class="hidden md:flex flex-1 max-w-md relative">
      <input
        type="search"
        name="q"
        placeholder="ค้นหาติวเตอร์ สถาบัน วิชา โรงเรียน..."
        class="w-full rounded-full border border-gray-300 px-4 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
      />
      <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-indigo-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </button>
    </form>

    <nav class="flex items-center gap-1 text-sm">
      <a href="/category/por1/" class={`px-3 py-2 rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition-colors ${isActive('/category/por1') ? 'text-indigo-600 font-medium' : 'text-gray-700'}`}>ป.1</a>
      <a href="/category/mor1/" class={`px-3 py-2 rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition-colors ${isActive('/category/mor1') ? 'text-indigo-600 font-medium' : 'text-gray-700'}`}>ม.1</a>
      <a href="/category/mor4/" class={`px-3 py-2 rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition-colors ${isActive('/category/mor4') ? 'text-indigo-600 font-medium' : 'text-gray-700'}`}>ม.4</a>
      <a href="/category/uni/" class={`px-3 py-2 rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition-colors ${isActive('/category/uni') ? 'text-indigo-600 font-medium' : 'text-gray-700'}`}>มหาวิทยาลัย</a>
      <a href="/tool/find-my-tutor/" class="ml-2 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium text-sm hidden sm:inline-block">หาติวเตอร์ที่ใช่</a>
    </nav>
  </div>
</header>
