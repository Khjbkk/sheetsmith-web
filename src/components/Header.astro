---
const navItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'สอบเข้า ป.1', href: '/exams/por1/' },
  { label: 'สอบเข้า ม.1', href: '/exams/mor1/' },
  { label: 'สอบเข้า ม.4', href: '/exams/mor4/' },
  { label: 'บทความ', href: '/blog/' },
  { label: 'เกี่ยวกับเรา', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-md border-b border-border sticky top-0 z-50 transition-shadow duration-300" id="site-header">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-[68px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.png" alt="SheetSmith" width="42" height="42" class="rounded-lg shadow-sm group-hover:shadow transition-shadow duration-200" />
        <div class="flex flex-col leading-tight">
          <span class="font-heading text-lg font-bold text-primary tracking-tight">SheetSmith</span>
          <span class="text-[10px] text-text-muted font-medium tracking-wide">ชีทติวสอบ ประถม-มัธยม</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-0.5">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'bg-primary text-white shadow-sm'
                : 'text-text-light hover:text-primary hover:bg-primary-light',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-text-light hover:bg-bg-warm active:scale-95 transition-all"
        aria-label="เปิดเมนู"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-border pt-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'bg-primary text-white'
              : 'text-text-light hover:text-primary hover:bg-primary-light',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Add shadow on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
