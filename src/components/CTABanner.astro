---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  variant?: 'primary' | 'secondary';
}

const {
  title = 'พร้อมเริ่มฝึกทำข้อสอบแล้วหรือยัง?',
  description = 'ดาวน์โหลดตัวอย่างข้อสอบฟรี พร้อมเฉลยละเอียดทุกข้อ',
  buttonText = 'ดูตัวอย่างข้อสอบฟรี',
  buttonHref = '/exams/',
  variant = 'primary',
} = Astro.props;

const bgClass = variant === 'primary'
  ? 'bg-gradient-to-r from-primary to-primary-dark'
  : 'bg-gradient-to-r from-secondary to-secondary-dark';
---

<section class={`${bgClass} rounded-2xl p-8 md:p-12 text-white text-center my-12`}>
  <h2 class="font-heading text-2xl md:text-3xl font-bold mb-3">{title}</h2>
  <p class="text-white/90 mb-6 max-w-2xl mx-auto">{description}</p>
  <a
    href={buttonHref}
    class="inline-block bg-white text-primary font-semibold px-8 py-3 rounded-xl hover:bg-gray-100 transition-colors"
  >
    {buttonText}
  </a>
</section>
