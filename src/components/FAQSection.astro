---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
}

const { title = 'คำถามที่พบบ่อย', items } = Astro.props;

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="my-12">
  <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">{title}</h2>
  <div class="space-y-2">
    {items.map((item) => (
      <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-indigo-300 transition-colors">
        <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer font-medium text-gray-900 hover:text-indigo-600 transition-colors">
          <span>{item.question}</span>
          <svg class="w-5 h-5 shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 border-t border-gray-100 pt-3">
          <p class="leading-relaxed">{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
